---
interface Props {
	title: string;
	category: string;
	description: string;
	class?: string;
}

const { title, category, description, class: className } = Astro.props as Props;

const descriptionLines = description.split('\n').filter(Boolean);
const isMultiLine = descriptionLines.length > 1;
const isHorizontal = className?.includes('award-card--horizontal');
---

<!-- 
  AWARD CARD — PROTECTED DESIGN
  Do not modify layout, colors, typography, spacing, or hover effects without explicit approval.
  This card design is finalized for the admissions portfolio.
  Uses .card--light from global.css card system.
  Auto-detects multi-line descriptions and renders as bullet list.
  Horizontal variant for Scholarships/Certificates.
-->

<article class:list={['card card--light award-card', isHorizontal && 'award-card--horizontal', className]}>
	<p class="award-card__category">{category}</p>
	<h3 class="award-card__title">{title}</h3>
	{isMultiLine ? (
		<ul class="award-card__description">
			{descriptionLines.map((line) => <li>{line}</li>)}
		</ul>
	) : (
		<p class="award-card__description">{description}</p>
	)}
</article>

<style>
	/* AWARD CARD STYLES — DO NOT MODIFY WITHOUT APPROVAL */
	.award-card {
		display: flex;
		flex-direction: column;
		gap: 1.125rem;
		min-width: 0;
		width: 100%;
		padding: clamp(2.25rem, 4.5vw, 3rem);
		border-radius: 18px;
		border: 1px solid var(--card-border);
		box-shadow:
			0 3px 12px rgba(0, 0, 0, 0.045),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.award-card:hover {
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.09),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transform: translateY(-3px);
	}

	/* Horizontal variant — entirely horizontal, single line */
	.award-card--horizontal {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: clamp(1.5rem, 3vw, 2rem);
		padding: clamp(1.25rem, 2.5vw, 1.75rem) clamp(2rem, 4vw, 3rem);
	}

	.award-card--horizontal .award-card__category {
		white-space: nowrap;
		min-width: max-content;
		margin-right: clamp(1.5rem, 2vw, 2rem);
		flex-shrink: 0;
	}

	.award-card--horizontal .award-card__title {
		flex: 1;
		min-width: 0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		margin: 0 clamp(1rem, 2vw, 1.5rem) 0 0;
	}

	.award-card--horizontal .award-card__description {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		flex: 1;
		min-width: 0;
		text-align: right;
	}

	/* Hide category label on very small screens for horizontal cards */
	@media (max-width: 600px) {
		.award-card--horizontal .award-card__category {
			display: none;
		}
	}

	.award-card__category,
	.award-card__title,
	.award-card__description {
		margin: 0;
	}

	.award-card__category {
		font-size: clamp(1.2rem, 1.35vw, 1.35rem);
		line-height: 1.4;
		color: var(--accent);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.075em;
	}

	.award-card__title {
		font-size: clamp(1.6875rem, 2.1vw, 2.25rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.award-card__description {
		font-size: clamp(1.425rem, 1.5vw, 1.575rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
	}

	.award-card__description li {
		margin: 0.375rem 0;
		padding-left: 0.75rem;
	}

	.award-card__description li::marker {
		color: var(--accent);
	}
</style>