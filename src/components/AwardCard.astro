---
interface Props {
	title: string;
	category: string;
	description: string;
}

const { title, category, description } = Astro.props as Props;

const descriptionLines = description.split('\n').filter(Boolean);
const isMultiLine = descriptionLines.length > 1;
---

<!-- 
  AWARD CARD — PROTECTED DESIGN
  Do not modify layout, colors, typography, spacing, or hover effects without explicit approval.
  This card design is finalized for the admissions portfolio.
  Uses .card--light from global.css card system.
  Auto-detects multi-line descriptions and renders as bullet list.
-->

<article class="card card--light award-card">
	<p class="award-card__category">{category}</p>
	<h3 class="award-card__title">{title}</h3>
	{isMultiLine ? (
		<ul class="award-card__description">
			{descriptionLines.map((line) => <li>{line}</li>)}
		</ul>
	) : (
		<p class="award-card__description">{description}</p>
	)}
</article>

<style>
	/* AWARD CARD STYLES — DO NOT MODIFY WITHOUT APPROVAL */
	.award-card {
		display: flex;
		flex-direction: column;
		gap: 1.125rem;
		min-width: 0;
		width: 100%;
		padding: clamp(2.25rem, 4.5vw, 3rem);
		border-radius: 18px;
		border: 1px solid var(--card-border);
		box-shadow:
			0 3px 12px rgba(0, 0, 0, 0.045),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.award-card:hover {
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.09),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transform: translateY(-3px);
	}

	.award-card__category,
	.award-card__title,
	.award-card__description {
		margin: 0;
	}

	.award-card__category {
		font-size: clamp(1.2rem, 1.35vw, 1.35rem);
		line-height: 1.4;
		color: var(--accent);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.075em;
	}

	.award-card__title {
		font-size: clamp(1.6875rem, 2.1vw, 2.25rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.award-card__description {
		font-size: clamp(1.425rem, 1.5vw, 1.575rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
	}

	.award-card__description li {
		margin: 0.375rem 0;
		padding-left: 0.75rem;
	}

	.award-card__description li::marker {
		color: var(--accent);
	}
</style>