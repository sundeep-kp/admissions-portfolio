---
import { awardItems } from '../data/awards';
import AwardCard from './AwardCard.astro';
---

<section class="awards section-fade" aria-labelledby="awards-title" id="awards" style="background: var(--bg-neutral); color: var(--text-primary);">
	<div class="awards__inner">
		<h2 id="awards-title">Awards</h2>

		<div class="awards__categories">
			{awardItems.map((award) => (
				<details class="awards__category">
					<summary class="awards__category-summary">
						<span class="awards__category-title">{award.category}</span>
						<span class="awards__category-count">1 item</span>
					</summary>
					<div class="awards__grid">
						<AwardCard title={award.title} category={award.category} description={award.description} />
					</div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.awards {
		padding: clamp(3rem, 6vw, 6rem) clamp(1rem, 5vw, 4rem);
	}

	.awards__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 3rem);
	}

	.awards__categories {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.awards__category {
		border: 1px solid var(--card-border);
		border-radius: 12px;
		overflow: hidden;
		background: var(--card-bg);
	}

	.awards__category[open] {
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.05);
	}

	.awards__category summary {
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 1.5rem;
		cursor: pointer;
		background: var(--bg-white);
		border-bottom: 1px solid var(--card-border);
		transition: background 0.2s ease;
	}

	.awards__category summary::-webkit-details-marker {
		display: none;
	}

	.awards__category summary::after {
		content: '';
		width: 0.5rem;
		height: 0.5rem;
		border-right: 2px solid var(--accent);
		border-bottom: 2px solid var(--accent);
		transform: rotate(45deg);
		transition: transform 0.2s ease;
		flex-shrink: 0;
		margin-left: 1rem;
	}

	.awards__category[open] summary::after {
		transform: rotate(-135deg);
	}

	.awards__category summary:hover {
		background: var(--accent-soft);
	}

	.awards__category summary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: -2px;
	}

	.awards__category-title {
		font-size: clamp(1.125rem, 1.5vw, 1.5rem);
		font-weight: 600;
		color: var(--text-primary);
	}

	.awards__category-count {
		font-size: clamp(0.875rem, 1vw, 1rem);
		color: var(--accent);
		font-weight: 500;
	}

	.awards__grid {
		padding: 1.5rem;
	}

	.awards h2 {
		margin: 0;
		font-size: clamp(1.5rem, 2.5vw, 2.25rem);
		line-height: 1.1;
	}

	@media (min-width: 768px) {
		.awards__categories {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 1.5rem;
		}

		.awards__category {
			flex: 1 1 calc(33.333% - 1rem);
			min-width: 280px;
		}
	}
</style>