---
/*
 * CAROUSEL COMPONENT — CRITICAL SHARED INFRASTRUCTURE
 * =====================================================
 * This component is used by ALL carousels: Leadership, Projects (Robotics, Software),
 * and About Me. Any change here affects ALL sections globally.
 *
 * DO NOT:
 * - Change perPage default (2.86) — desktop cards rely on ~35% width from this value
 * - Change global breakpoints (767, 1024) — all sections share these responsive rules
 * - Add `mediaQuery: 'min'` to Splide config — it breaks breakpoint matching order
 * - Set `overflow: hidden` on .splide — it clips navigation arrows
 * - Remove `position: relative` from .splide — arrows position absolutely inside it
 * - Set `width: 100%` on .splide__list — it overrides Splide's perPage width calculations
 * - Add `max-width` on card components (.leadership-card, .project-card) — the carousel
 *   controls card width via perPage; fixed max-width values conflict and cause layout shifts
 *
 * WHY perPage = 2.86:
 *   Splide uses max-width breakpoints (applied largest-first). At desktop (≥1024px),
 *   no max-width breakpoint matches, so the base perPage applies. 100/2.86 ≈ 35% width.
 *   The 767 breakpoint overrides to perPage: 1.18 (~85%) on mobile.
 *
 * WHY no `mediaQuery: 'min'`:
 *   Splide's default is max-width matching (smallest breakpoint first). Adding
 *   mediaQuery: 'min' reverses the order, causing mobile breakpoints to not match
 *   on small screens, resulting in cards stuck at 100% width.
 */
interface Props {
  children: any;
  autoplay?: boolean;
  autoplayInterval?: number;
  showArrows?: boolean;
  showDots?: boolean;
  class?: string;
  id?: string;
  customScroll?: boolean;
  perPage?: number;
  perMove?: number;
  gap?: string;
  breakpoints?: Record<number, { perPage?: number; gap?: string }>;
  type?: 'loop' | 'slide';
}

const {
  children,
  autoplay = false,
  autoplayInterval = 5000,
  showArrows = true,
  showDots = true,
  class: className,
  id,
  customScroll = false,
  perPage = 2.86,   /* DO NOT CHANGE — desktop ~35% width. Mobile overridden by 767 breakpoint to 1.18 (~85%) */
  perMove = 1,
  gap = '1.5rem',
  breakpoints = {},
  type = 'loop',     /* Auto-switches to 'slide' if any breakpoint has fractional perPage */
} = Astro.props as Props;

const breakpointsJSON = JSON.stringify(breakpoints);
---

<div class:list={['splide', className]} role="region" aria-label="Carousel" id={id}
  data-autoplay={autoplay ? 'true' : 'false'}
  data-autoplay-interval={String(autoplayInterval)}
  data-arrows={showArrows ? 'true' : 'false'}
  data-dots={showDots ? 'true' : 'false'}
  data-custom-scroll={customScroll ? 'true' : 'false'}
  data-per-page={String(perPage)}
  data-per-move={String(perMove)}
  data-gap={gap}
  data-breakpoints={breakpointsJSON}
  data-type={type}>
  <div class="splide__track">
    <ul class="splide__list">
      <slot />
    </ul>
  </div>

  {showArrows && (
    <div class="splide__arrows" aria-hidden="true">
      <button class="splide__arrow splide__arrow--prev" type="button" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="splide__arrow splide__arrow--next" type="button" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  )}

  {showDots && (
    <div class="splide__pagination" aria-label="Slide indicators"></div>
  )}
</div>

<script>
  /*
   * CAROUSEL INITIALIZATION — DO NOT MODIFY without understanding the full impact.
   *
   * CRITICAL RULES:
   * 1. Do NOT add `mediaQuery: 'min'` — it reverses Splide's breakpoint matching order,
   *    causing mobile breakpoints to not fire on small screens (cards stuck at 100%).
   * 2. Do NOT remove the fractional perPage auto-detection (lines 127-135) — loop mode
   *    crashes when any perPage value is fractional (e.g., 1.18 or 2.86).
   * 3. Do NOT set `dataset.splideInit` before `splide.mount()` — if mount throws,
   *    the carousel is permanently stuck uninitialized.
   * 4. Do NOT change globalBreakpoints values — all carousels (Leadership, Projects,
   *    About Me) share these. Mobile: 1.18 perPage (~85%), Desktop: 2.86 (~35%).
   * 5. Do NOT add `overflow: hidden` to .splide CSS — it clips the navigation arrows.
   * 6. Do NOT add `width: 100%` to .splide__list — it overrides Splide's perPage width
   *    calculations and forces all slides to fit within the container.
   */
  async function initSplide() {
    const { Splide } = await import('@splidejs/splide');

    const splideElements = document.querySelectorAll('.splide');
    splideElements.forEach((el) => {
      if (el.dataset.splideInit) return;

      const autoplay = el.dataset.autoplay === 'true';
      const interval = parseInt(el.dataset.autoplayInterval) || 5000;
      const arrows = el.dataset.arrows === 'true';
      const dots = el.dataset.dots === 'true';
      const customScroll = el.dataset.customScroll === 'true';
      const perPage = parseFloat(el.dataset.perPage) || 2.86;
      const perMove = parseInt(el.dataset.perMove) || 1;
      const gap = el.dataset.gap || '1.5rem';
      const type = el.dataset.type || 'loop';
      let rawCustomBreakpoints = {};
      try {
        rawCustomBreakpoints = JSON.parse(el.dataset.breakpoints || '{}');
      } catch {}

      /*
       * GLOBAL BREAKPOINTS — shared by ALL carousels.
       *
       * Splide uses max-width matching (smallest breakpoint first):
       *   - At ≤767px: 767 breakpoint fires → perPage: 1.18 (~85% width), free scroll, no arrows
       *   - At 768-1023px: no breakpoint matches → base perPage: 2.86 (~35% width) applies
       *   - At ≥1024px: no breakpoint matches → base perPage: 2.86 (~35% width) applies
       *
       * Sections may override via the `breakpoints` prop (e.g., Leadership adds 768: { perPage: 1.2 }
       * for a tablet peek effect). Custom breakpoints are merged AFTER globals via spread.
       */
      const globalBreakpoints: Record<number, Record<string, unknown>> = {
        767: { perPage: 1.18, gap: '1rem', arrows: true, pagination: false, drag: 'free', snap: false, focus: 'center' },
        1024: { perPage: 2.86, gap: '1.5rem', drag: 'free', snap: false },
        9999: { drag: 'free', snap: false, focus: 'center' },
      };

      const customBreakpoints: Record<number, Record<string, unknown>> = {};
      Object.entries(rawCustomBreakpoints).forEach(([key, val]) => {
        customBreakpoints[parseInt(key)] = val;
      });
      const allBreakpoints = { ...globalBreakpoints, ...customBreakpoints };

      /*
       * FRACTIONAL perPage AUTO-DETECTION:
       * Splide's `type: 'loop'` mode requires integer perPage values for clone math.
       * If any perPage (base or breakpoint) is fractional (e.g., 1.18, 2.86), we
       * automatically switch to `type: 'slide'` to prevent mount failures.
       *
       * DO NOT remove this check — it prevents cascading initialization failures
       * across all carousels on the page.
       */
      let effectiveType = type;
      if (type === 'loop') {
        const allPerPageValues = [perPage, ...Object.values(allBreakpoints).map(b => b.perPage).filter(Boolean)];
        const hasFractionalPerPage = allPerPageValues.some(v => v !== undefined && v !== Math.floor(v));
        if (hasFractionalPerPage) {
          effectiveType = 'slide';
        }
      }

      const splide = new Splide(el, {
        type: customScroll ? 'slide' : effectiveType,
        perPage,
        perMove,
        gap,
        arrows,
        pagination: dots,
        autoplay,
        interval,
        pauseOnHover: true,
        pauseOnFocus: true,
        drag: 'free',
        snap: false,
        breakpoints: allBreakpoints,
      });

      try {
        splide.mount();
        el.dataset.splideInit = 'true';
        el.splide = splide;

        // Trackpad horizontal scroll → carousel navigation
        let lastWheelTime = 0;
        el.addEventListener('wheel', (e) => {
          if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) {
            const now = Date.now();
            if (now - lastWheelTime < 350) return;
            lastWheelTime = now;
            if (e.deltaX > 0) splide.go('>');
            else splide.go('<');
          }
        }, { passive: true });
      } catch (err) {
        console.error('[Carousel] Splide mount failed:', err);
        try { splide.destroy(); } catch {}
      }
    });
  }

  initSplide();
</script>

<style>
  /*
   * CAROUSEL BASE STYLES — DO NOT MODIFY without testing ALL sections.
   *
   * These styles control the fundamental carousel layout. Changes here affect
   * Leadership, Projects (Robotics, Software), and About Me carousels.
   *
   * DO NOT:
   * - Add `overflow: hidden` to .splide — clips navigation arrows
   * - Remove `position: relative` from .splide — arrows need it for absolute positioning
   * - Add `width: 100%` to .splide__list — overrides Splide's perPage width calculations
   */

  /* Splide carousel container — DO NOT add overflow:hidden here */
  .splide {
    width: 100%;
    overflow: visible;  /* DO NOT change to hidden — clips navigation arrows */
    position: relative; /* DO NOT remove — arrows position absolutely inside this */
  }

  /* Slide track — this clips the slides (overflow:hidden is correct here) */
  .splide__track {
    overflow: hidden;
    width: 100%;
  }

  /* Slide list — DO NOT add width:100% here — breaks Splide's perPage calculations */
  .splide__list {
    display: flex;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* Individual slides — controlled by Splide's perPage */
  :global(.splide__slide) {
    flex-shrink: 0;
    min-width: 0;
  }

  /* Arrows */
  .splide__arrows {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 1rem;
    pointer-events: none;
    z-index: 10;
  }

  .splide__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    cursor: pointer;
    pointer-events: auto;
    transition: background 0.2s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    color: var(--text-primary);
  }

  .splide__arrow:hover:not(:disabled) {
    background: var(--accent);
    color: var(--text-on-dark);
    transform: scale(1.1);
  }

  .splide__arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .splide__arrow:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Pagination dots */
  .splide__pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0;
  }

  .splide__pagination__page {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--card-border);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .splide__pagination__page:hover {
    background: var(--accent);
    transform: scale(1.2);
  }

  .splide__pagination__page.is-active {
    background: var(--accent);
  }

  /* Card styling — shared base for all carousel card types.
   * Section-specific theming (colors, backgrounds) is in each section's .astro file.
   * DO NOT add width/max-width here — the carousel controls card width via perPage. */
  :global(.splide__slide > .about-carousel__card),
  :global(.splide__slide > .about-card),
  :global(.splide__slide > .project-card),
  :global(.splide__slide > .leadership-card) {
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--bg-white);
    border-radius: 18px;
    border: 1px solid var(--card-border);
    box-shadow:
      0 3px 12px rgba(0, 0, 0, 0.045),
      inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  :global(.splide__slide > .about-carousel__card:hover),
  :global(.splide__slide > .about-card:hover),
  :global(.splide__slide > .project-card:hover),
  :global(.splide__slide > .leadership-card:hover) {
    box-shadow:
      0 12px 36px rgba(0, 0, 0, 0.09),
      inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
    transform: translateY(-3px);
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    :global(.splide__slide) {
      transition: none !important;
    }
  }

  /* Mobile adjustments — hides arrows and pagination on small screens.
   * The 767 breakpoint in globalBreakpoints enables free-scroll instead.
   * DO NOT remove this — mobile UX relies on swipe, not buttons. */
  @media (max-width: 767px) {
    .splide__arrows,
    .splide__pagination {
      display: none !important;
    }
  }
</style>