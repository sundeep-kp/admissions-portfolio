---
interface Props {
  children: any;
  autoplay?: boolean;
  autoplayInterval?: number;
  showArrows?: boolean;
  showDots?: boolean;
  class?: string;
  id?: string;
  customScroll?: boolean;
  perPage?: number;
  perMove?: number;
  gap?: string;
  breakpoints?: Record<number, { perPage?: number; gap?: string }>;
  type?: 'loop' | 'slide';
}

const {
  children,
  autoplay = false,
  autoplayInterval = 5000,
  showArrows = true,
  showDots = true,
  class: className,
  id,
  customScroll = false,
  perPage = 2.86,
  perMove = 1,
  gap = '1.5rem',
  breakpoints = {},
  type = 'loop',
} = Astro.props as Props;

const breakpointsJSON = JSON.stringify(breakpoints);
---

<div class:list={['splide', className]} role="region" aria-label="Carousel" id={id}
  data-autoplay={autoplay ? 'true' : 'false'}
  data-autoplay-interval={String(autoplayInterval)}
  data-arrows={showArrows ? 'true' : 'false'}
  data-dots={showDots ? 'true' : 'false'}
  data-custom-scroll={customScroll ? 'true' : 'false'}
  data-per-page={String(perPage)}
  data-per-move={String(perMove)}
  data-gap={gap}
  data-breakpoints={breakpointsJSON}
  data-type={type}>
  <div class="splide__track">
    <ul class="splide__list">
      <slot />
    </ul>
  </div>

  {showArrows && (
    <div class="splide__arrows" aria-hidden="true">
      <button class="splide__arrow splide__arrow--prev" type="button" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="splide__arrow splide__arrow--next" type="button" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  )}

  {showDots && (
    <div class="splide__pagination" aria-label="Slide indicators"></div>
  )}
</div>

<script>
  // Initialize Splide carousel - dynamically import to avoid SSR issues
  async function initSplide() {
    const { Splide } = await import('@splidejs/splide');

    const splideElements = document.querySelectorAll('.splide');
    splideElements.forEach((el) => {
      if (el.dataset.splideInit) return;

      const autoplay = el.dataset.autoplay === 'true';
      const interval = parseInt(el.dataset.autoplayInterval) || 5000;
      const arrows = el.dataset.arrows === 'true';
      const dots = el.dataset.dots === 'true';
      const customScroll = el.dataset.customScroll === 'true';
      const perPage = parseFloat(el.dataset.perPage) || 1;
      const perMove = parseInt(el.dataset.perMove) || 1;
      const gap = el.dataset.gap || '1.5rem';
      const type = el.dataset.type || 'loop';
      let rawCustomBreakpoints = {};
      try {
        rawCustomBreakpoints = JSON.parse(el.dataset.breakpoints || '{}');
      } catch {}

      // Global default breakpoints - all carousels use these unless overridden
      const globalBreakpoints: Record<number, Record<string, unknown>> = {
        767: { perPage: 1.18, gap: '1rem', arrows: true, pagination: false, drag: 'free', snap: false, focus: 'center' },
        1024: { perPage: 2.86, gap: '1.5rem' },
      };

      // Merge: custom breakpoints override globals, keys converted to numbers
      const customBreakpoints: Record<number, Record<string, unknown>> = {};
      Object.entries(rawCustomBreakpoints).forEach(([key, val]) => {
        customBreakpoints[parseInt(key)] = val;
      });
      const allBreakpoints = { ...globalBreakpoints, ...customBreakpoints };

      // Check if any breakpoint has fractional perPage - loop mode doesn't support it
      let effectiveType = type;
      if (type === 'loop') {
        const allPerPageValues = [perPage, ...Object.values(allBreakpoints).map(b => b.perPage).filter(Boolean)];
        const hasFractionalPerPage = allPerPageValues.some(v => v !== undefined && v !== Math.floor(v));
        if (hasFractionalPerPage) {
          effectiveType = 'slide';
        }
      }

      const splide = new Splide(el, {
        type: customScroll ? 'slide' : effectiveType,
        perPage,
        perMove,
        gap,
        arrows,
        pagination: dots,
        autoplay,
        interval,
        pauseOnHover: true,
        pauseOnFocus: true,
        drag: true,
        snap: true,
        breakpoints: allBreakpoints,
      });

      try {
        splide.mount();
        // Only mark as initialized AFTER successful mount
        el.dataset.splideInit = 'true';
        // Store instance on element for debugging/access
        el.splide = splide;
      } catch (err) {
        console.error('[Carousel] Splide mount failed:', err);
        // Do NOT set splideInit - allow retry on next initSplide() call
        // Clean up any partial state
        try { splide.destroy(); } catch {}
      }
    });
  }

  initSplide();
</script>

<style>
  /* Splide carousel container */
  .splide {
    width: 100%;
    overflow: visible;
    position: relative;
  }

  .splide__track {
    overflow: hidden;
    width: 100%;
  }

  .splide__list {
    display: flex;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global(.splide__slide) {
    flex-shrink: 0;
    min-width: 0;
  }

  /* Arrows */
  .splide__arrows {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 1rem;
    pointer-events: none;
    z-index: 10;
  }

  .splide__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    cursor: pointer;
    pointer-events: auto;
    transition: background 0.2s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    color: var(--text-primary);
  }

  .splide__arrow:hover:not(:disabled) {
    background: var(--accent);
    color: var(--text-on-dark);
    transform: scale(1.1);
  }

  .splide__arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .splide__arrow:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Pagination dots */
  .splide__pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0;
  }

  .splide__pagination__page {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--card-border);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .splide__pagination__page:hover {
    background: var(--accent);
    transform: scale(1.2);
  }

  .splide__pagination__page.is-active {
    background: var(--accent);
  }

  /* Card styling for carousel slides */
  :global(.splide__slide > .about-carousel__card),
  :global(.splide__slide > .about-card),
  :global(.splide__slide > .project-card),
  :global(.splide__slide > .leadership-card) {
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--bg-white);
    border-radius: 18px;
    border: 1px solid var(--card-border);
    box-shadow:
      0 3px 12px rgba(0, 0, 0, 0.045),
      inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  :global(.splide__slide > .about-carousel__card:hover),
  :global(.splide__slide > .about-card:hover),
  :global(.splide__slide > .project-card:hover),
  :global(.splide__slide > .leadership-card:hover) {
    box-shadow:
      0 12px 36px rgba(0, 0, 0, 0.09),
      inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
    transform: translateY(-3px);
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    :global(.splide__slide) {
      transition: none !important;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 767px) {
    .splide__arrows,
    .splide__pagination {
      display: none !important;
    }
  }
</style>