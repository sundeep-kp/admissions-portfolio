---
interface Props {
	children: any;
	autoplay?: boolean;
	autoplayInterval?: number;
	showArrows?: boolean;
	showDots?: boolean;
	class?: string;
	customScroll?: boolean;
	id?: string;
}

const { children, autoplay = false, autoplayInterval = 5000, showArrows = true, showDots = true, class: className, customScroll = false, id } = Astro.props as Props;
---

<div class:list={['carousel', className, customScroll && 'carousel--custom-scroll']} role="region" aria-label="Carousel" id={id} data-custom-scroll={customScroll ? 'true' : 'false'} data-autoplay={autoplay ? 'true' : 'false'} data-autoplay-interval={String(autoplayInterval)}>
	<div class="carousel__track" data-carousel-track>
		<slot />
	</div>
</div>

	{showArrows && (
		<div class="carousel__arrows" aria-hidden="true">
			<button class="carousel__arrow carousel__arrow--prev" aria-label="Previous" data-carousel-prev>
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>
			<button class="carousel__arrow carousel__arrow--next" aria-label="Next" data-carousel-next>
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>
		</div>
	)}

	{showDots && (
		<div class="carousel__dots" aria-label="Slide indicators" data-carousel-dots>
			<!-- Dots will be generated by JS -->
		</div>
	)}
</div>

<style is:global>
	.carousel {
		position: relative;
		width: 100%;
		overflow: hidden;
	}

	.carousel__track {
		display: flex;
		/* Native continuous scrolling with snap */
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
		-ms-overflow-style: none;
		gap: var(--card-gap, 1.5rem);
		padding: 0 0 1rem;
	}

	/* Disable scroll-snap for custom scroll carousel (Robotics - 25% width cards) */
	.carousel--custom-scroll .carousel__track {
		scroll-snap-type: none;
	}

	.carousel__track::-webkit-scrollbar {
		display: none;
	}

	.carousel__track > *,
		.carousel__track > :global(*) {
			flex: 0 0 100%;
			min-width: 0;
			scroll-snap-align: start;
		}

	.carousel__arrows {
		position: absolute;
		top: 50%;
		left: 0;
		right: 0;
		transform: translateY(-50%);
		display: flex;
		justify-content: space-between;
		padding: 0 1rem;
		pointer-events: none;
		z-index: 10;
	}

	.carousel__arrow {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: none;
		background: rgba(255, 255, 255, 0.9);
		border-radius: 50%;
		cursor: pointer;
		pointer-events: auto;
		transition: background 0.2s ease, transform 0.2s ease;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		color: var(--text-primary);
	}

	.carousel__arrow:hover {
		background: var(--accent);
		color: var(--text-on-dark);
		transform: scale(1.1);
	}

	.carousel__arrow:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.carousel__dots {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
		padding: 1rem 0;
	}

	.carousel__dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		border: none;
		background: var(--card-border);
		cursor: pointer;
		transition: background 0.2s ease, transform 0.2s ease;
	}

	.carousel__dot:hover {
		background: var(--accent);
		transform: scale(1.2);
	}

	.carousel__dot--active {
		background: var(--accent);
	}

	/* Mobile: free scroll, cards ~25% width */
	@media (max-width: 767px) {
		.carousel__track {
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			-ms-overflow-style: none;
			padding-bottom: 1rem;
			gap: 1rem;
		}

		/* Disable snap for custom scroll carousel on mobile too */
		.carousel--custom-scroll .carousel__track {
			scroll-snap-type: none;
		}

		.carousel__track > *,
		.carousel__track > :global(*) {
			flex: 0 0 25%;
			max-width: 25%;
			scroll-snap-align: start;
		}

		.carousel__arrows,
		.carousel__dots {
			display: none !important;
		}
	}

	/* Desktop: controlled carousel with arrows/dots, 1 card per view (100% width) */
	@media (min-width: 768px) {
		.carousel__track {
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			-ms-overflow-style: none;
			gap: var(--card-gap, 1.5rem);
			padding-bottom: 1rem;
		}

		.carousel__track::-webkit-scrollbar {
			display: none;
		}

		.carousel__track > *,
		.carousel__track > :global(*) {
			flex: 0 0 100%;
			max-width: 100%;
			scroll-snap-align: start;
		}

		.carousel__arrows,
		.carousel__dots {
			display: flex;
		}
	}

	@media (min-width: 1024px) {
		.carousel__track > *,
		.carousel__track > :global(*) {
			flex: 0 0 calc(33.333% - 1rem);
			max-width: calc(33.333% - 1rem);
		}
	}

	</style>