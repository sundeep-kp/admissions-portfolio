---
import asciiArt from '/images/ascii-art.txt?raw';
import asciiArtMobile from '/images/ascii-art-mobile.txt?raw';
---

<section class="hero section-fade" aria-labelledby="hero-title" style="color: var(--text-primary);">
	<div class="hero__ascii-bg" role="img" aria-label="Ornithopter ASCII art" aria-hidden="true">
		<pre class="hero__ascii hero__ascii--desktop">{asciiArt}</pre>
	</div>
	<div class="hero__inner">
		<div class="hero__ascii-mobile" aria-hidden="true">
			<pre class="hero__ascii hero__ascii--mobile" aria-hidden="true">{asciiArtMobile}</pre>
		</div>
		<div class="hero__content">
			<h1 id="hero-title">Sundeep Kumar Panigrahi</h1>

			<p class="hero__intro">~ a robotics enthusiast</p>

			<div class="hero__university" aria-label="University">
				<span class="hero__university-label">Current institution</span>
				IIIT Naya Raipur
			</div>

			<div class="hero__divider" aria-hidden="true"></div>

			<div class="hero__goals" aria-label="Goals">
				<!-- Goals section structure:
				     - .hero__goals-title: "Goals" title (uppercase, primary text color)
				     - .hero__goal--long: Long-term goal (pink accent #E723C1)
				     - .hero__goal--short: Short-term goals group (purple accent #6F23E7)
				         - Contains two .hero__short-term-item separated by .hero__short-term-separator (vertical line)
				     DO NOT add more items without updating CSS selectors (.hero__goal:nth-child(n)) -->
				<h3 class="hero__goals-title">Goals</h3>
				<p class="hero__goal hero__goal--long"><strong>Long-term:</strong> Explore bio-inspired robotics research</p>
				<p class="hero__goal hero__goal--short">
					<strong>Short-term:</strong>
					<span class="hero__short-term-item">Design of mechanisms</span>
					<span class="hero__short-term-separator" aria-hidden="true"></span>
					<span class="hero__short-term-item">Physics behind robotics</span>
				</p>
			</div>
			<!-- Goals section: single long-term goal + short-term items separated by vertical line.
			     Short-term items use flex layout with vertical separator (.hero__short-term-separator).
			     DO NOT split short-term into separate .hero__goal elements - they share one container. -->

			<div class="hero__divider" aria-hidden="true"></div>

			<div class="hero__buttons" aria-label="Action links">
				<a class="hero__btn hero__btn--glass" href="https://canva.link/0zsjufwpj3qsscc" target="_blank" rel="noopener noreferrer">Resume</a>
				<a class="hero__btn hero__btn--glass" href="https://github.com/sundeep-kp/ros2-roadmap-ultralab/" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a class="hero__btn hero__btn--glass" href="https://www.linkedin.com/in/sundeepskp" target="_blank" rel="noopener noreferrer">LinkedIn</a>
			</div>

			<div class="hero__emails" aria-label="Email contacts">
				<p class="hero__email"><strong>Email (admissions, personal):</strong> panigrahisundeep99@gmail.com</p>
				<p class="hero__email"><strong>Email (media inquiries):</strong> halfwiredtv@gmail.com</p>
			</div>

			<div class="hero__essay" aria-label="Personal essay">
				<button class="hero__btn hero__btn--essay" id="essay-toggle" type="button" aria-haspopup="dialog" aria-expanded="false" aria-controls="essay-popup">
					Personal Essay
				</button>
				<div class="essay-popup" id="essay-popup" role="dialog" aria-modal="true" aria-label="Choose a personal essay" hidden>
					<button class="essay-popup__backdrop" type="button" aria-label="Close menu" tabindex="-1"></button>
					<div class="essay-popup__card">
						<button class="essay-popup__close" type="button" aria-label="Close menu">&times;</button>
						<p class="essay-popup__title">Personal Essays</p>
						<a class="essay-popup__link" href="https://docs.google.com/document/d/1wZBQ0YcKrGHTGD6Mi6aIgIC3AYStBb1c7h5OecGGStA/edit?usp=sharing" target="_blank" rel="noopener noreferrer">
							I am not gonna take no for an answer
						</a>
						<a class="essay-popup__link" href="https://docs.google.com/document/d/16rFKkcL5JnGTjFElnYYbEhNawBqrLeqjsWjKo8gT5zc/edit?tab=t.0#heading=h.5xgg81bihh9p" target="_blank" rel="noopener noreferrer">
							Tiny Robots Big Dreams
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		padding-inline: var(--section-padding-inline);
		padding-top: clamp(0.25rem, 1vw, 0.75rem);
		display: flex;
		align-items: flex-start;
		justify-content: center;
		position: relative;
		background: var(--bg-white);
	}

	/* ASCII background art — bottom-most layer */
	.hero__ascii-bg {
		position: absolute;
		right: 0;
		top: 37%;
		transform: translateY(-50%);
		width: fit-content;
		aspect-ratio: 1 / 1;
		z-index: 0;
		pointer-events: none;
	}

	.hero__inner {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: var(--section-gap);
		position: relative;
		z-index: 1;
	}

	.hero__content,
	.hero__visual,
	.hero__ascii {
		min-width: 0;
	}

	.hero__content {
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 2.5vw, 2rem);
		padding-top: clamp(0.5rem, 1vw, 1rem);
		position: relative;
		z-index: 1; /* above ASCII art */
	}

	/* Name */
	.hero__content > h1 {
		margin: 0;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 1.05;
		letter-spacing: -0.02em;
		font-weight: 700;
		color: var(--text-primary);
	}

	/* Intro */
	.hero__intro {
		margin: 0;
		font-size: clamp(1.125rem, 1.8vw, 1.375rem);
		line-height: 1.5;
		color: var(--text-primary);
		opacity: 0.7;
		font-style: italic;
	}

	/* University badge */
	.hero__university {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0;
		font-size: clamp(0.875rem, 1.2vw, 1rem);
		font-weight: 500;
		color: var(--text-primary);
		opacity: 0.85;
	}

	.hero__university-label {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-primary);
		opacity: 0.5;
	}

	.hero__university-label::after {
		content: ':';
	}

	/* Divider */
	.hero__divider {
		width: 100%;
		max-width: 200px;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.08), transparent);
	}

	/* Goals
 * Structure: 
 *   - .hero__goals-title: "Goals" heading (uppercase, primary text color)
 *   - .hero__goal--long: single long-term goal item (pink accent #E723C1)
 *   - .hero__goal--short: flex container holding two short-term items with vertical separator
 *   - .hero__short-term-separator: vertical line (1px) between short-term items
 *   - No left accent borders on goal items (removed per design decision)
 * DO NOT change structure to separate short-term items into individual .hero__goal elements.
 * DO NOT add left accent borders back. */
	.hero__goals {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.hero__goals-title {
		margin: 0 0 0.5rem;
		font-size: clamp(0.875rem, 1.2vw, 1rem);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.075em;
		color: var(--text-primary);
	}

	.hero__goal {
		margin: 0;
		font-size: clamp(0.875rem, 1.1vw, 1rem);
		line-height: 1.6;
		color: var(--text-primary);
		opacity: 0.85;
		padding: 0.75rem 1rem;
		border-radius: 8px;
		transition: background 0.2s ease, opacity 0.2s ease;
	}

	.hero__goal:hover {
		opacity: 1;
		background: rgba(0, 0, 0, 0.03);
	}

	/* Short-term items with vertical separator */
	.hero__goal--short {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.hero__short-term-item {
		display: flex;
		align-items: center;
	}

	.hero__short-term-separator {
		width: 1px;
		height: 1.2em;
		background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.15), transparent);
	}

	.hero__goal strong {
		font-weight: 600;
		opacity: 0.95;
	}

	/* Buttons */
	.hero__buttons {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(0.75rem, 1.25vw, 1rem);
	}

	.hero__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.875rem 1.5rem;
		font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
		font-weight: 500;
		color: var(--text-primary);
		text-decoration: none;
		border-radius: 12px;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.hero__btn--glass {
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid rgba(0, 0, 0, 0.06);
		border-radius: 14px;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow:
			0 2px 8px rgba(0, 0, 0, 0.04),
			inset 0 1px 0 rgba(255, 255, 255, 0.6),
			inset 0 -1px 0 rgba(0, 0, 0, 0.02);
	}

	.hero__btn--glass:hover {
		background: rgba(255, 255, 255, 0.85);
		border-color: rgba(0, 0, 0, 0.1);
		box-shadow:
			0 8px 24px rgba(0, 0, 0, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.7),
			inset 0 -1px 0 rgba(0, 0, 0, 0.03);
		transform: translateY(-2px);
	}

	.hero__btn--essay {
		background: var(--accent);
		color: var(--text-on-dark);
		border: 1px solid var(--accent);
		border-radius: 14px;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow:
			0 2px 8px rgba(0, 0, 0, 0.04),
			inset 0 1px 0 rgba(255, 255, 255, 0.3),
			inset 0 -1px 0 rgba(0, 0, 0, 0.02);
	}

	.hero__btn--essay:hover {
		background: var(--accent-strong);
		border-color: var(--accent-strong);
		box-shadow:
			0 8px 24px rgba(0, 0, 0, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.4),
			inset 0 -1px 0 rgba(0, 0, 0, 0.03);
		transform: translateY(-2px);
	}

	.hero__btn:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	/* Essay popup */
	.hero__essay {
		position: relative;
	}

	.essay-popup {
		position: fixed;
		inset: 0;
		z-index: 1000;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
	}

	.essay-popup[hidden] {
		display: none;
	}

	.essay-popup__backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.3);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		border: none;
		cursor: default;
	}

	.essay-popup__card {
		position: relative;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid rgba(0, 0, 0, 0.06);
		border-radius: 16px;
		box-shadow:
			0 4px 24px rgba(0, 0, 0, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.6);
		padding: 2rem 1.75rem 1.75rem;
		width: 100%;
		max-width: 22rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		animation: essayPopupIn 0.15s ease;
	}

	@keyframes essayPopupIn {
		from {
			opacity: 0;
			transform: scale(0.95);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	.essay-popup__close {
		position: absolute;
		top: 0.5rem;
		right: 0.75rem;
		background: none;
		border: none;
		font-size: 1.5rem;
		line-height: 1;
		color: var(--text-primary);
		opacity: 0.4;
		cursor: pointer;
		padding: 0.25rem;
		transition: opacity 0.15s ease;
	}

	.essay-popup__close:hover {
		opacity: 0.8;
	}

	.essay-popup__title {
		margin: 0 0 0.25rem;
		font-size: clamp(0.8rem, 1.1vw, 0.9rem);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.075em;
		color: var(--text-primary);
		opacity: 0.5;
	}

	.essay-popup__link {
		display: block;
		padding: 0.875rem 1.25rem;
		font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
		font-weight: 500;
		color: var(--text-primary);
		text-decoration: none;
		background: var(--accent);
		color: var(--text-on-dark);
		border-radius: 12px;
		transition: background 0.15s ease, transform 0.15s ease;
	}

	.essay-popup__link:hover {
		background: var(--accent-strong);
		transform: translateY(-1px);
	}

	.essay-popup__link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	/* Emails */
	.hero__emails {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.hero__email {
		margin: 0;
		font-size: clamp(0.875rem, 1.1vw, 1rem);
		line-height: 1.5;
		color: var(--text-primary);
		opacity: 0.75;
	}

	.hero__email strong {
		font-weight: 600;
		opacity: 0.9;
	}

	/* Mobile ASCII — circular profile */
	.hero__ascii-mobile {
		display: block;
		width: fit-content;
		margin: 0 auto;
		margin-bottom: clamp(0.25rem, 1vw, 0.5rem);
	}

	.hero__ascii-mobile .hero__ascii {
		width: max-content;
		margin: 0;
		padding: 0.5rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 50%;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: clamp(1.584rem, 3.3vw, 1.98rem);
		line-height: 1.1;
		overflow: hidden;
		white-space: pre;
		background: rgba(255, 255, 255, 0.7);
		zoom: 0.072; /* DO NOT CHANGE — calibrated to fit mobile ascii art in circular profile pic; changing breaks layout */
		clip-path: none;
		aspect-ratio: 1 / 1;
	}

	/* Desktop ASCII art */
	.hero__ascii {
		width: max-content;
		margin: 0;
		padding: 1.5rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 18px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: clamp(3.41545248rem, 4.55393664vw, 4.17444192rem);
		line-height: 1.1;
		overflow: hidden;
		white-space: pre;
		background: rgba(255, 255, 255, 0.7);
		zoom: 0.08; /* DO NOT CHANGE — calibrated for desktop ascii art; changing breaks right-edge alignment */
		clip-path: inset(20% 0 10% 5%);
	}

	.hero__ascii--desktop {
		display: none;
	}

	.hero__ascii--mobile {
		display: block;
		clip-path: none;
		zoom: 0.05; /* DO NOT CHANGE — calibrated for mobile ascii art in circular profile pic */
	}

	@supports not (zoom: 0.1) {
	  .hero__ascii {
	    zoom: 1; /* fallback for browsers without zoom support */
	    font-size: clamp(0.22rem, 0.33vw, 0.33rem);
	    line-height: 1.0;
	  }
	}

	@media (max-width: 767px) {
		.hero__visual {
			display: none;
		}

		.hero__ascii-bg {
			display: none;
		}
	}

	@media (min-width: 768px) {
		.hero__inner {
			flex-direction: row;
			gap: clamp(2rem, 4vw, 4rem);
			align-items: center;
		}

		.hero__content {
			flex: 1 1 50%;
			min-width: 0;
		}

		.hero__visual {
			flex: 1 1 50%;
			display: flex;
			justify-content: flex-end;
		}

		.hero__buttons {
			justify-content: flex-start;
		}

		.hero__ascii-mobile {
			display: none;
		}

		.hero__ascii-bg {
			display: block;
		}

		.hero__ascii--desktop {
			display: block;
		}

		.hero__ascii--mobile {
			display: none;
		}
	}
</style>

<script>
	function initEssayPopup() {
		const toggle = document.getElementById('essay-toggle');
		const popup = document.getElementById('essay-popup');
		if (!toggle || !popup) return;

		const backdrop = popup.querySelector('.essay-popup__backdrop');
		const closeBtn = popup.querySelector('.essay-popup__close');
		const links = popup.querySelectorAll('.essay-popup__link');

		function openPopup() {
			popup.hidden = false;
			toggle.setAttribute('aria-expanded', 'true');
			closeBtn.focus();
			document.addEventListener('keydown', onKeydown);
		}

		function closePopup() {
			popup.hidden = true;
			toggle.setAttribute('aria-expanded', 'false');
			toggle.focus();
			document.removeEventListener('keydown', onKeydown);
		}

		function onKeydown(e) {
			if (e.key === 'Escape') {
				closePopup();
				return;
			}
			if (e.key === 'Tab') {
				const focusable = [closeBtn, ...links];
				const first = focusable[0];
				const last = focusable[focusable.length - 1];
				if (e.shiftKey && document.activeElement === first) {
					e.preventDefault();
					last.focus();
				} else if (!e.shiftKey && document.activeElement === last) {
					e.preventDefault();
					first.focus();
				}
			}
		}

		toggle.addEventListener('click', openPopup);
		backdrop.addEventListener('click', closePopup);
		closeBtn.addEventListener('click', closePopup);
		links.forEach((link) => {
			link.addEventListener('click', closePopup);
		});
	}

	initEssayPopup();
	document.addEventListener('astro:after-swap', initEssayPopup);
</script>