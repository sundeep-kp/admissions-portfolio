---
import asciiArt from '/images/ascii-art.txt?raw';
import asciiArtMobile from '/images/ascii-art-mobile.txt?raw';
---

<section class="hero section-fade" aria-labelledby="hero-title" style="background: var(--bg-white); color: var(--text-primary);">
	<div class="hero__inner">
		<div class="hero__ascii-mobile" aria-hidden="true">
			<pre class="hero__ascii hero__ascii--mobile">{asciiArtMobile}</pre>
		</div>
		<div class="hero__content">
			<p>Sundeep</p>
			<h1 id="hero-title">Sundeep Kumar Panigrahi</h1>

			<p>One-line introduction</p>

			<p>Current university : IIIT, naya raipur</p>

			<p>Research interests :</p>
			<p>Bio inspired robotics</p>
<ul>
				<li>- for Planetary exploration</li>
				<li>- Non-Invasive Wildlife Observation</li>
			</ul>

			<div class="hero__buttons" aria-label="Buttons">
				<a href="[edit the one from hacknation in canva – include ornithopter and current books I am studying, and the ongoing projects: RL based pick n place robotic arm from scratch]">Resume</a>
				<a href="https://github.com/sundeep-kp/ros2-roadmap-ultralab/">GitHub</a>
				<a href="https://www.linkedin.com/in/sundeepskp">LinkedIn</a>
				<a href="mailto:panigrahisundeep99@gmail.com">Email</a>
				<a href="mailto:halfwiredtv@email...">Half Wired TV</a>
			</div>
</div>

<div class="hero__ascii-container" role="img" aria-label="Ornithopter ASCII art">
			<pre class="hero__ascii hero__ascii--desktop" aria-hidden="true">{asciiArt}</pre>
		</div>
</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		padding-inline: var(--section-padding-inline);
		padding-top: clamp(0.25rem, 1vw, 0.75rem);
		display: flex;
		align-items: flex-start;
		justify-content: center;
	}

	.hero__inner {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: var(--section-gap);
		position: relative;
		z-index: 1;
	}

	.hero__content,
	.hero__visual,
	.hero__ascii-container,
	.hero__ascii {
		min-width: 0;
	}

	.hero__content {
		display: flex;
		flex-direction: column;
		gap: clamp(0.75rem, 1.5vw, 1rem);
		padding-top: clamp(0.25rem, 0.5vw, 0.5rem);
	}

	.hero__buttons {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(0.75rem, 1.5vw, 1rem);
	}

.hero__ascii-mobile {
		display: block;
		width: fit-content;
		margin: 0 auto;
		margin-bottom: clamp(0.25rem, 1vw, 0.5rem);
	}

	.hero__ascii-mobile .hero__ascii {
		width: max-content;
		margin: 0;
		padding: 0.5rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 50%;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: clamp(1.584rem, 3.3vw, 1.98rem);
		line-height: 1.1;
		overflow: hidden;
		white-space: pre;
		background: rgba(255, 255, 255, 0.7);
		zoom: 0.072; /* DO NOT CHANGE — calibrated to fit mobile ascii art in circular profile pic; changing breaks layout */
		clip-path: none;
		aspect-ratio: 1 / 1;
	}

	.hero__ascii-container {
		width: fit-content;
		margin-left: auto;
		margin-right: 0;
		aspect-ratio: 1.2 / 1;
	}

	.hero__ascii {
		width: max-content;
		margin: 0;
		padding: 1.5rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 18px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: clamp(3.41545248rem, 4.55393664vw, 4.17444192rem);
		line-height: 1.1;
		overflow: hidden;
		white-space: pre;
		background: rgba(255, 255, 255, 0.7);
		zoom: 0.08; /* DO NOT CHANGE — calibrated for desktop ascii art; changing breaks right-edge alignment */
		clip-path: inset(20% 0 10% 5%);
	}

	.hero__ascii--desktop {
		display: none;
	}

	.hero__ascii--mobile {
		display: block;
		clip-path: none;
		zoom: 0.05; /* DO NOT CHANGE — calibrated for mobile ascii art in circular profile pic */
	}

	@supports not (zoom: 0.1) {
	  .hero__ascii {
	    zoom: 1; /* fallback for browsers without zoom support */
	    font-size: clamp(0.22rem, 0.33vw, 0.33rem);
	    line-height: 1.0;
	  }
	}

	@media (max-width: 767px) {
		.hero__visual {
			display: none;
		}
	}

	@media (min-width: 768px) {
		.hero__inner {
			flex-direction: row;
			gap: clamp(2rem, 4vw, 4rem);
			align-items: center;
		}

		.hero__content {
			flex: 1 1 50%;
			min-width: 0;
		}

		.hero__visual {
			flex: 1 1 50%;
			display: flex;
			justify-content: flex-end;
		}

		.hero__buttons {
			justify-content: flex-start;
		}

		.hero__ascii-mobile {
			display: none;
		}

		.hero__ascii-container {
			aspect-ratio: 1 / 1;
			position: absolute;
			right: 0; /* DO NOT CHANGE — pinned to right edge of hero */
			top: 72%; /* DO NOT CHANGE — calibrated vertical position; changing shifts art into other sections */
			transform: translateY(-50%); /* centers container vertically on top value */
		}

		.hero__ascii--desktop {
			display: block;
		}

		.hero__ascii--mobile {
			display: none;
		}
	}
</style>