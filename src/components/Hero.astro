---
import asciiArt from '/images/ascii-art.txt?raw';
import asciiArtMobile from '/images/ascii-art-mobile.txt?raw';
---

<section class="hero section-fade" aria-labelledby="hero-title" style="background: var(--bg-white); color: var(--text-primary);">
	<div class="hero__inner">
		<div class="hero__content">
			<p>Sundeep</p>
			<h1 id="hero-title">Sundeep Kumar Panigrahi</h1>

			<p>One-line introduction</p>

			<p>Current university : IIIT, naya raipur</p>

			<p>Research interests :</p>
			<p>Bio inspired robotics</p>
<ul>
				<li>- for Planetary exploration</li>
				<li>- Non-Invasive Wildlife Observation</li>
			</ul>

			<div class="hero__buttons" aria-label="Buttons">
				<a href="[edit the one from hacknation in canva – include ornithopter and current books I am studying, and the ongoing projects: RL based pick n place robotic arm from scratch]">Resume</a>
				<a href="https://github.com/sundeep-kp/ros2-roadmap-ultralab/">GitHub</a>
				<a href="https://www.linkedin.com/in/sundeepskp">LinkedIn</a>
				<a href="mailto:panigrahisundeep99@gmail.com">Email</a>
				<a href="mailto:halfwiredtv@email...">Half Wired TV</a>
			</div>
		</div>

<div class="hero__visual" aria-label="Ornithopter ASCII art">
<div class="hero__ascii-container" role="img" aria-label="Ornithopter ASCII art">
  			<pre class="hero__ascii hero__ascii--desktop" aria-hidden="true">{asciiArt}</pre>
        <pre class="hero__ascii hero__ascii--mobile" aria-hidden="true">{asciiArtMobile}</pre>
  		</div>
  		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		padding-inline: var(--section-padding-inline);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero__inner {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: clamp(2.25rem, 4.5vw, 7.5rem);
		position: relative;
		z-index: 1;
	}

 .hero__content,
  		.hero__visual,
  		.hero__ascii-container,
  		.hero__ascii {
  			min-width: 0;
  		}

	.hero__content {
		display: flex;
		flex-direction: column;
		gap: clamp(1.125rem, 2.25vw, 1.875rem);
	}

	.hero__buttons {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(1.125rem, 2.25vw, 1.875rem);
	}

.hero__ascii-container {
		width: 320px;
		height: 200px;
		margin: 0 auto;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
	}

  .hero__ascii {
		margin: 0;
		padding: 1.5rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 18px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: clamp(1.6335rem, 2.178vw, 1.9965rem);
		line-height: 1.1;
		white-space: pre;
		background: rgba(255, 255, 255, 0.7);
		transform-origin: center center;
	}

	.hero__ascii--desktop {
		display: block;
		transform: scale(0.185);
	}

	.hero__ascii--mobile {
		display: none;
		transform: scale(0.31);
	}

	.hero p,
	.hero h1,
	.hero ul {
		margin: 0;
	}

	.hero h1 {
		font-size: clamp(2.25rem, 7.5vw, 5rem);
		line-height: 0.95;
	}

	.hero p,
	.hero li,
	.hero a {
		font-size: clamp(1rem, 1.65vw, 1.25rem);
		line-height: 1.6;
		color: inherit;
	}

	.hero ul {
		padding-left: 1.875rem;
	}

	@media (min-width: 768px) {
		.hero__inner {
			flex-direction: row;
			gap: clamp(2rem, 4vw, 4rem);
			align-items: center;
		}

		.hero__content {
			flex: 1 1 50%;
			min-width: 0;
		}

		.hero__visual {
			flex: 1 1 50%;
			display: flex;
			justify-content: center;
		}

		.hero__buttons {
			justify-content: flex-start;
		}

		.hero__ascii--desktop {
			display: block;
			transform: scale(0.185);
		}

		.hero__ascii--mobile {
			display: none;
		}
	}

	@media (max-width: 767px) {
		.hero__ascii--desktop {
			display: none;
		}

		.hero__ascii--mobile {
			display: block;
			transform: scale(0.31);
		}
	}
</style>
