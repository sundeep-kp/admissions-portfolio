---
import asciiArt from '/images/ascii-art.txt?raw';
import asciiArtMobile from '/images/ascii-art-mobile.txt?raw';
---

<section class="hero section-fade" aria-labelledby="hero-title" style="background: #ffffff; color: #1a1a1a;">
	<div class="hero__inner">
		<div class="hero__content">
			<p>Name</p>
			<h1 id="hero-title">[Name Missing]</h1>

			<p>One-line introduction</p>

			<p>Current university : IIIT, naya raipur</p>

			<p>Research interests :</p>
			<p>Bio inspired robotics</p>
<ul>
				<li>- for Planetary exploration</li>
				<li>- Non-Invasive Wildlife Observation</li>
			</ul>

			<div class="hero__buttons" aria-label="Buttons">
				<a href="[edit the one from hacknation in canva – include ornithopter and current books I am studying, and the ongoing projects: RL based pick n place robotic arm from scratch]">Resume</a>
				<a href="https://github.com/sundeep-kp/ros2-roadmap-ultralab/">GitHub</a>
				<a href="https://www.linkedin.com/in/sundeepskp">LinkedIn</a>
				<a href="mailto:panigrahisundeep99@gmail.com">Email</a>
				<a href="mailto:halfwiredtv@email...">Half Wired TV</a>
			</div>
		</div>

<div class="hero__visual" aria-label="Ornithopter ASCII art">
<div class="hero__ascii-container" role="img" aria-label="Ornithopter ASCII art">
  			<pre class="hero__ascii hero__ascii--desktop" aria-hidden="true">{asciiArt}</pre>
        <pre class="hero__ascii hero__ascii--mobile" aria-hidden="true">{asciiArtMobile}</pre>
  		</div>
  		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		padding-inline: clamp(1rem, 5vw, 4rem);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero__inner {
		width: 100%;
		max-width: 1200px;
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 5rem);
		position: relative;
		z-index: 1;
	}

 .hero__content,
  		.hero__visual,
  		.hero__ascii-container,
  		.hero__ascii {
  			min-width: 0;
  		}

	.hero__content {
		display: flex;
		flex-direction: column;
		gap: clamp(0.75rem, 1.5vw, 1.25rem);
	}

	.hero__buttons {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(0.75rem, 1.5vw, 1.25rem);
	}

.hero__ascii-container {
  		width: fit-content;
      margin: 0 auto;
  	}

  .hero__ascii {
		width: max-content;
		margin: 0;
		padding: 1rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 12px;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
		font-size: clamp(0.9rem, 1.2vw, 1.1rem);
		line-height: 1.1;
		overflow: hidden;
		white-space: pre;
		background: rgba(255, 255, 255, 0.7);
    zoom: 0.185;
    clip-path: inset(28% 0 20% 12%); /* top 28% / right 0 / bottom 20% / left 12% — DO NOT CHANGE without design review */
	}

	.hero__ascii--desktop {
		display: none;
	}

	.hero__ascii--mobile {
		display: block;
    clip-path: inset(1%); /* all sides 1% — MOBILE ONLY — DO NOT CHANGE without design review */
    zoom: 0.31; /* MOBILE ONLY — DO NOT CHANGE without design review */
	}

	@supports not (zoom: 0.185) {
	  .hero__ascii {
	    zoom: 1;
	    font-size: clamp(0.13rem, 0.2vw, 0.2rem);
	    line-height: 1.0;
	  }
	}

	@media (min-width: 768px) {
		.hero__ascii--desktop {
			display: block;
		}

		.hero__ascii--mobile {
			display: none;
		}
	}

	.hero p,
	.hero h1,
	.hero ul {
		margin: 0;
	}

	.hero h1 {
		font-size: clamp(2.25rem, 5vw, 5rem);
		line-height: 0.95;
	}

	.hero p,
	.hero li,
	.hero a {
		font-size: clamp(1rem, 1.1vw, 1.125rem);
		line-height: 1.6;
		color: inherit;
	}

	.hero ul {
		padding-left: 1.25rem;
	}

	@media (min-width: 768px) {
		.hero__inner {
			flex-direction: row;
			gap: clamp(0.35rem, 0.9vw, 0.65rem);
			align-items: center;
		}

		.hero__content {
			flex: 0 0 55%;
			max-width: 55%;
		}

		.hero__visual {
			flex: 1 1 auto;
			max-width: 100%;
			display: flex;
			justify-content: center;
			margin-left: -20%;
		}

		.hero__buttons {
			justify-content: flex-start;
		}
	}
</style>
