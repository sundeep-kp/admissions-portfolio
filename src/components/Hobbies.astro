---
const hobbies = [
	{ title: 'Music', detail: 'Guitar, tabla, singing, a bit of bass, drums, and flute.' },
	{ title: 'Film', detail: 'Photography, film production, storytelling, and stop-motion animation.' },
	{ title: 'Painting', detail: 'Digital art and painting.' },
	{ title: 'Behavioural Psychology', detail: 'Behavioural psychology.' },
];
---

<section class="hobbies" aria-labelledby="hobbies-title" id="hobbies">
	<div class="hobbies__inner">
		<h2 id="hobbies-title">Hobbies</h2>

		<div class="hobbies__grid">
			{hobbies.map((hobby) => (
				<article class="hobbies-card">
					<h3>{hobby.title}</h3>
					<p>{hobby.detail}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.hobbies {
		padding: clamp(3rem, 6vw, 6rem) clamp(1rem, 5vw, 4rem);
	}

	.hobbies__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 3rem);
	}

	.hobbies__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1rem, 2vw, 1.5rem);
		width: 100%;
	}

	.hobbies-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-width: 0;
		width: 100%;
		padding: clamp(1.25rem, 2.5vw, 2rem);
		background: rgba(250, 227, 246, 0.35);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-radius: 16px;
		border: 1px solid rgba(255, 255, 255, 0.5);
		box-shadow:
			0 4px 16px rgba(0, 0, 0, 0.04),
			inset 0 1px 0 rgba(255, 255, 255, 0.6);
	}

	.hobbies h2,
	.hobbies h3,
	.hobbies p {
		margin: 0;
	}

	.hobbies h2 {
		font-size: clamp(1.75rem, 2.5vw, 3rem);
		line-height: 1.1;
	}

	.hobbies h3 {
		font-size: clamp(1.125rem, 1.4vw, 1.5rem);
		line-height: 1.25;
	}

	.hobbies p {
		font-size: clamp(1rem, 1.05vw, 1.1rem);
		line-height: 1.6;
	}

	/* auto-fit handles desktop expansion without fixed breakpoints */
</style>