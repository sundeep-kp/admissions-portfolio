---
import Carousel from './Carousel.astro';
import CarouselSlide from './CarouselSlide.astro';

const instagramUrls = [
	'https://www.instagram.com/reel/DY3ifXjRKwg/',
	'https://www.instagram.com/reel/Dah7W3AONxW/',
	'https://www.instagram.com/reel/DXRVekfDtls/',
	'https://www.instagram.com/p/DVOm-y6E5YX/',
	'https://www.instagram.com/p/DT2v2GXDVs1/',
	'https://www.instagram.com/p/CyoZVOEhWVo/',
	'https://www.instagram.com/p/CyoZk2ihJtT/',
	'https://www.instagram.com/p/Cyvpk1ELhX0/',
	'https://www.instagram.com/p/C18YbzFiMCj/',
	'https://www.instagram.com/p/C4S1fCIxXp3/',
	'https://www.instagram.com/p/DCepytZzQ8S/',
];
---

<section class="hobbies section-fade" aria-labelledby="hobbies-title" id="hobbies" style="background: var(--accent); color: var(--text-primary);">
	<div class="hobbies__inner">
		<h2 id="hobbies-title">Hobbies</h2>

		<Carousel
			id="hobbies-carousel"
			autoplay={false}
			showArrows={true}
			showDots={false}
			type="slide"
			perMove={1}
		breakpoints={{
			767: { perPage: 1, snap: false, drag: 'free', focus: false, gap: '1rem', arrows: true, pagination: false },
			1024: { perPage: 1, snap: false, drag: 'free', focus: false, gap: '1.5rem' },
			9999: { snap: false, drag: 'free', focus: false },
		}}
			class="hobbies__carousel"
		>
			<CarouselSlide>
				<article class="card card--light hobbies-card">
					<h3>Music, Film & Art</h3>
					<p>Guitar, tabla, singing, bass, drums, flute, beatbox. Photography, film production, storytelling, stop-motion animation. Digital art, painting, origami, recreating outfits.</p>
				</article>
			</CarouselSlide>
			<CarouselSlide>
				<article class="card card--light hobbies-card">
					<h3>Psychology</h3>
					<p>Behavioural psychology, psychology of communication.</p>
				</article>
			</CarouselSlide>
		{instagramUrls.map((url) => (
			<CarouselSlide>
				<a class="hobbies__slide" href={url} target="_blank" rel="noopener noreferrer">
					<div class="hobbies__drag-handle" aria-hidden="true">
						<span class="hobbies__drag-pill"></span>
					</div>
					<div class="hobbies__embed-zone">
						<blockquote class="instagram-media" data-instgrm-permalink={url} data-instgrm-version="14" style="max-width:540px; width:100%;"></blockquote>
					</div>
				</a>
			</CarouselSlide>
		))}
		</Carousel>
		<div class="hobbies__swipe-hint" aria-hidden="true">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 12h14M12 5l7 7-7 7"/>
			</svg>
		</div>
	</div>
</section>

<script>
	function initEmbedZones() {
		document.querySelectorAll('.hobbies__embed-zone').forEach((zone) => {
			zone.addEventListener('pointerdown', (e) => {
				e.stopPropagation();
			}, true);
		});
	}

	initEmbedZones();
	document.addEventListener('astro:after-swap', initEmbedZones);
</script>

<style>
	.hobbies {
		padding: clamp(3rem, 8vw, 6rem) var(--section-padding-inline);
	}

	.hobbies__inner {
		width: 100%;
		margin: 0 auto;
	}

	.hobbies h2 {
		margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
		font-size: clamp(1.5rem, 2.5vw, 2.25rem);
		line-height: 1.1;
	}

	.hobbies-card {
		display: flex;
		flex-direction: column;
		gap: 1.125rem;
		min-width: 0;
		width: 100%;
		padding: clamp(2.25rem, 4.5vw, 3rem);
		border-radius: 18px;
		border: 1px solid var(--card-border);
		box-shadow:
			0 3px 12px rgba(0, 0, 0, 0.045),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.hobbies-card:hover {
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.09),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transform: translateY(-3px);
	}

	.hobbies h3 {
		margin: 0;
		font-size: clamp(1.125rem, 1.5vw, 1.375rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.hobbies p {
		margin: 0;
		font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
	}

	/* Instagram slide layout */
	.hobbies__slide {
		display: flex;
		flex-direction: column;
		height: 100%;
		border-radius: 18px;
		overflow: hidden;
		border: 1px solid var(--card-border);
		background: rgba(255, 255, 255, 0.7);
		box-shadow:
			0 3px 12px rgba(0, 0, 0, 0.045),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		text-decoration: none;
		color: inherit;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.hobbies__slide:hover {
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.09),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transform: translateY(-3px);
	}

	/* Drag handle — top 48px, touch zone for Splide */
	.hobbies__drag-handle {
		flex: 0 0 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: grab;
		touch-action: pan-y;
		user-select: none;
	}

	.hobbies__drag-handle:active {
		cursor: grabbing;
	}

	.hobbies__drag-pill {
		width: 32px;
		height: 4px;
		border-radius: 2px;
		background: rgba(0, 0, 0, 0.15);
		transition: background 0.15s ease;
	}

	.hobbies__drag-handle:hover .hobbies__drag-pill {
		background: rgba(0, 0, 0, 0.25);
	}

	/* Embed zone — rest of card, touches pass to Splide by default */
	.hobbies__embed-zone {
		flex: 1;
		min-height: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(0.5rem, 1vw, 1rem);
	}

	.hobbies__embed-zone :global(.instagram-media) {
		border-radius: 12px;
		overflow: hidden;
		pointer-events: none;
	}

	.hobbies__embed-zone :global(.instagram-media iframe) {
		pointer-events: none;
	}

	/* Carousel theming — accent background with dark text */
	.hobbies__carousel :global(.splide__arrow) {
		background: rgba(255, 255, 255, 0.9);
		width: 40px;
		height: 40px;
	}

	.hobbies__carousel :global(.splide__arrow:hover:not(.is-disabled)) {
		background: var(--accent-strong);
		color: var(--text-on-dark);
	}

	.hobbies__carousel :global(.splide__arrow svg) {
		fill: var(--text-primary);
	}

	.hobbies__carousel :global(.splide__arrow:hover:not(.is-disabled) svg) {
		fill: var(--text-on-dark);
	}

	.hobbies__carousel :global(.splide__pagination__page) {
		background: var(--card-border);
	}

	.hobbies__carousel :global(.splide__pagination__page.is-active) {
		background: var(--accent);
	}

	/* Mobile: hide arrows and pagination */
	@media (max-width: 767px) {
		.hobbies__carousel :global(.splide__arrows),
		.hobbies__carousel :global(.splide__pagination) {
			display: none !important;
		}
	}

	/* Desktop: tighter card padding in carousel */
	@media (min-width: 768px) {
		.hobbies__carousel :global(.hobbies-card) {
			padding: clamp(0.1rem, 1vw, 1rem) !important;
			gap: clamp(0.1rem, 0.1vw, 0.1rem) !important;
		}

		.hobbies__carousel :global(.hobbies-card h3) {
			font-size: clamp(1rem, 1.3vw, 1.2rem) !important;
		}

		.hobbies__carousel :global(.hobbies-card p) {
			font-size: clamp(0.875rem, 1.1vw, 1rem) !important;
			line-height: 1.5 !important;
		}
	}

	/* Swipe hint — hidden by default, shown on mobile */
	.hobbies__swipe-hint {
		display: none;
	}

	/* Mobile: smaller card padding + swipe hint */
	@media (max-width: 767px) {
		.hobbies__carousel :global(.hobbies-card) {
			padding: clamp(0.5rem, 2vw, 1rem);
			gap: clamp(0.5rem, 1vw, 1rem);
		}

		.hobbies__drag-handle {
			flex: 0 0 36px;
		}

		.hobbies__embed-zone {
			padding: clamp(0.25rem, 0.5vw, 0.5rem);
		}

		.hobbies__swipe-hint {
			display: flex;
			align-items: center;
			justify-content: center;
			margin-top: clamp(0.75rem, 1.5vw, 1rem);
			color: var(--text-primary);
			opacity: 0.4;
			animation: swipeHintBob 1.5s ease-in-out infinite;
		}
	}

	@keyframes swipeHintBob {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(6px); }
	}
</style>
