---
const hobbies = [
	{ title: 'Music', detail: 'Guitar, tabla, singing, a bit of bass, drums, flute, and beatbox.' },
	{ title: 'Film', detail: 'Photography, film production, storytelling, and stop-motion animation.' },
	{ title: 'Art', detail: 'Digital art and painting, origami, recreating outfits.' },
	{ title: 'Psychology', detail: 'Behavioural psychology, psychology of communication.' },
];
---

<section class="hobbies section-fade" aria-labelledby="hobbies-title" id="hobbies" style="background: var(--accent); color: var(--text-primary);">
	<div class="hobbies__inner">
		<h2 id="hobbies-title">Hobbies</h2>

		<div class="hobbies__grid">
			{hobbies.map((hobby) => (
				<article class="card card--light hobbies-card">
					<h3>{hobby.title}</h3>
					<p>{hobby.detail}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.hobbies {
		padding: clamp(3rem, 8vw, 6rem) var(--section-padding-inline);
	}

	.hobbies__inner {
		width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(2.25rem, 4.5vw, 4.5rem);
	}

	.hobbies__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1.5rem, 3vw, 2.25rem);
		width: 100%;
	}

	.hobbies-card {
		display: flex;
		flex-direction: column;
		gap: 1.125rem;
		min-width: 0;
		width: 100%;
		padding: clamp(2.25rem, 4.5vw, 3rem);
		border-radius: 18px;
		border: 1px solid var(--card-border);
		box-shadow:
			0 3px 12px rgba(0, 0, 0, 0.045),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.hobbies-card:hover {
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.09),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transform: translateY(-3px);
	}

	.hobbies h2,
	.hobbies h3,
	.hobbies p {
		margin: 0;
	}

	.hobbies h2 {
		font-size: clamp(1.5rem, 2.5vw, 2.25rem);
		line-height: 1.1;
	}

	.hobbies h3 {
		font-size: clamp(1.125rem, 1.5vw, 1.375rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.hobbies p {
		font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
	}

	/* auto-fit handles desktop expansion without fixed breakpoints */
</style>