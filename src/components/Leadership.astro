---
import { leadershipItems } from '../data/leadership';
import LeadershipCard from './LeadershipCard.astro';

const featuredItem = leadershipItems.find(item => item.title === 'HalfwiredTV');
const otherItems = leadershipItems.filter(item => item.title !== 'HalfwiredTV');
---

<section class="leadership section-fade" aria-labelledby="leadership-title" id="leadership" style="background: var(--accent); color: var(--text-on-dark);">
	<div class="leadership__inner">
		<h2 id="leadership-title">Leadership and Community</h2>

		{featuredItem && (
			<LeadershipCard
				class="leadership-card--feature"
				title={featuredItem.title}
				description={featuredItem.description}
				links={featuredItem.links}
			/>
		)}

		<details class="leadership__expand">
			<summary class="leadership__expand-summary">
				Show all {otherItems.length} other leadership roles
			</summary>
			<div class="leadership__grid">
				{otherItems.map((item) => (
					<LeadershipCard
						title={item.title}
						description={item.description}
						links={item.links}
					/>
				))}
			</div>
		</details>
	</div>
</section>

<style>
	.leadership {
		padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 7.5vw, 6rem);
	}

	.leadership__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(2.25rem, 4.5vw, 4.5rem);
	}

	.leadership__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1.5rem, 3vw, 2.25rem);
		width: 100%;
	}

	.leadership h2 {
		margin: 0;
		font-size: clamp(1.75rem, 2.5vw, 3rem);
		line-height: 1.1;
	}

	.leadership__expand {
		margin-top: 1.5rem;
	}

	.leadership__expand summary {
		list-style: none;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.25rem;
		font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
		font-weight: 500;
		color: var(--accent);
		background: var(--accent-soft);
		border-radius: 999px;
		border: 1px solid var(--accent-border);
		transition: background 0.2s ease, color 0.2s ease;
	}

	.leadership__expand summary::-webkit-details-marker {
		display: none;
	}

	.leadership__expand summary::after {
		content: '';
		width: 0.5rem;
		height: 0.5rem;
		border-right: 2px solid currentColor;
		border-bottom: 2px solid currentColor;
		transform: rotate(45deg);
		transition: transform 0.2s ease;
		margin-left: 0.25rem;
	}

	.leadership__expand[open] summary::after {
		transform: rotate(-135deg);
	}

	.leadership__expand summary:hover {
		background: var(--accent);
		color: var(--text-on-dark);
	}

	.leadership__expand summary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.leadership__expand .leadership__grid {
		margin-top: 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--card-border-dark);
		animation: fadeIn 0.3s ease;
	}

@keyframes fadeIn {
		from { opacity: 0; transform: translateY(-0.5rem); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
