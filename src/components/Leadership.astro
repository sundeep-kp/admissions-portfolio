---
import { leadershipItems } from '../data/leadership';
import LeadershipCard from './LeadershipCard.astro';
import Carousel from './Carousel.astro';
import CarouselSlide from './CarouselSlide.astro';
---

<section class="leadership section-fade" aria-labelledby="leadership-title" id="leadership" style="background: var(--accent); color: var(--text-on-dark);">
	<div class="leadership__inner">
		<h2 id="leadership-title">Leadership and Community</h2>

<Carousel
			id="leadership-carousel"
			autoplay={false}
			showArrows={true}
			showDots={false}
			type="slide"
			class="leadership__carousel"
		>
			{leadershipItems.map((item) => (
				<CarouselSlide>
					<LeadershipCard
						title={item.title}
						description={item.description}
						links={item.links}
					/>
				</CarouselSlide>
			))}
		</Carousel>
	</div>
</section>

<style>
	.leadership {
		padding: var(--section-gap) var(--section-padding-inline);
	}

	.leadership__inner {
		width: 100%;
		margin: 0 auto;
	}

	/* Leadership carousel theming */
	.leadership__carousel .splide__arrow {
		background: rgba(255, 255, 255, 0.9);
		width: 40px;
		height: 40px;
	}

	.leadership__carousel .splide__arrow:hover:not(.is-disabled) {
		background: var(--accent);
		color: var(--text-on-dark);
	}

	.leadership__carousel .splide__arrow svg {
		fill: var(--text-primary);
	}

	.leadership__carousel .splide__arrow:hover:not(.is-disabled) svg {
		fill: var(--text-on-dark);
	}

	.leadership__carousel .splide__pagination__page {
		background: var(--card-border);
	}

	.leadership__carousel .splide__pagination__page.is-active {
		background: var(--accent);
	}

	/* Mobile: hide arrows and pagination */
	@media (max-width: 767px) {
		.leadership__carousel .splide__arrows,
		.leadership__carousel .splide__pagination {
			display: none !important;
		}
	}

	/* Desktop: let Splide control slide widths via perPage/breakpoints */
	@media (min-width: 768px) {
		.leadership__carousel :global(.leadership-card) {
			padding: clamp(0.1rem, 1vw, 1rem) !important;
			gap: clamp(0.1rem, 0.1vw, 0.1rem) !important;
		}

		.leadership__carousel :global(.leadership-card__body) {
			gap: clamp(0.5rem, 1vw, 0.75rem) !important;
		}

		.leadership__carousel :global(.leadership-card__text) {
			line-height: 1.5 !important;
			font-size: clamp(0.875rem, 1.2vw, 1rem) !important;
		}
	}

	/* Mobile: column layout */
	@media (max-width: 767px) {
		.leadership__inner {
			flex-direction: column;
			align-items: flex-start;
		}
		.leadership__carousel :global(.leadership-card) {
			padding: clamp(0.5rem, 2vw, 1rem);
			gap: clamp(0.5rem, 1vw, 1rem);
		}
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(-0.5rem); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>