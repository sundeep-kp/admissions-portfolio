---
import { leadershipItems } from '../data/leadership';
import LeadershipCard from './LeadershipCard.astro';
---

<section class="leadership section-fade" aria-labelledby="leadership-title" id="leadership" style="background: var(--accent); color: var(--text-on-dark);">
	<div class="leadership__inner">
		<h2 id="leadership-title">Leadership and Community</h2>

		<div class="leadership__grid">
			{leadershipItems.map((item) => (
				<LeadershipCard
					class:list={{ 'leadership-card--feature': item.title === 'HalfwiredTV' }}
					title={item.title}
					description={item.description}
					links={item.links}
				/>
			))}
		</div>
	</div>
</section>

<style>
	.leadership {
		padding: clamp(4.5rem, 9vw, 9rem) clamp(1.5rem, 7.5vw, 6rem);
	}

	.leadership__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(2.25rem, 4.5vw, 4.5rem);
	}

	.leadership__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1.5rem, 3vw, 2.25rem);
		width: 100%;
	}

	.leadership__grid :global(.leadership-card--feature) {
		grid-column: 1 / -1;
	}

	.leadership h2 {
		margin: 0;
		font-size: clamp(2.625rem, 3.75vw, 4.5rem);
		line-height: 1.1;
	}
</style>
