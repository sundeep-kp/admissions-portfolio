---
interface Props {
	title: string;
	description: string;
	links: Array<{ label: string; href: string }>;
}

const { title, description, links } = Astro.props as Props;
---

<article class="leadership-card">
	<h3>{title}</h3>
	<p>{description}</p>

	{links.length > 0 && (
		<ul class="leadership-card__links">
			{links.map((link) => (
				<li>
					<a href={link.href}>{link.label}</a>
				</li>
			))}
		</ul>
	)}
</article>

<style>
	.leadership-card {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: clamp(0.75rem, 1.5vw, 1rem);
		padding: clamp(1.25rem, 2.5vw, 2rem);
		width: 100%;
	}

	.leadership-card h3,
	.leadership-card p,
	.leadership-card__links {
		margin: 0;
	}

	.leadership-card h3 {
		font-size: clamp(1.125rem, 1.4vw, 1.5rem);
		line-height: 1.25;
	}

	.leadership-card p,
	.leadership-card__links {
		font-size: clamp(1rem, 1.05vw, 1.1rem);
		line-height: 1.6;
	}

	.leadership-card__links {
		padding-left: 1.25rem;
		display: grid;
		gap: 0.5rem;
	}
</style>