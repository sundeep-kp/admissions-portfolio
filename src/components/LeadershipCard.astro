---
interface Props {
	class?: string;
	title: string;
	description: string;
	links: Array<{ label: string; href: string }>;
}

const { title, description, links, class: className } = Astro.props as Props;

// Split description into paragraphs for better formatting
const descriptionLines = description.split('\n').filter(line => line.trim());

// Create preview (first 45 chars)
const fullDescription = descriptionLines.join(' ');
const preview = fullDescription.length > 45 ? fullDescription.slice(0, 45) + '…' : fullDescription;
const isExpandable = fullDescription.length > 45;
---

<!-- 
  LEADERSHIP CARD — PROTECTED DESIGN
  Do not modify layout, colors, typography, spacing, or hover effects without explicit approval.
  This card design is finalized for the admissions portfolio.
  Uses .card--dark from global.css card system.
  Now with collapsible description (45 char preview) and consistent dimensions.
-->

<article class:list={['card card--dark leadership-card', className]}>
	<header class="leadership-card__header">
		<h3>{title}</h3>
	</header>

	<div class="leadership-card__body">
		{isExpandable ? (
			<details class="leadership-card__details">
				<summary class="leadership-card__summary">
					{preview}
				</summary>
				<div class="leadership-card__full">
					{descriptionLines.map((line) => (
						<p class={line.startsWith('-') ? 'leadership-card__text leadership-card__bullet' : 'leadership-card__text'}>
							{line.startsWith('-') ? line.slice(1).trim() : line}
						</p>
					))}
					{links.length > 0 && links.some(l => l.href !== '#') && (
						<div class="leadership-card__links">
							{links.map((link) => link.href !== '#' && (
								<a href={link.href} class="leadership-card__link" target="_blank" rel="noopener noreferrer">
									{link.label}
									<svg class="leadership-card__link-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
										<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
										<polyline points="15 3 21 3 21 9" />
										<line x1="10" y1="14" x2="21" y2="3" />
									</svg>
								</a>
							))}
						</div>
					)}
				</div>
			</details>
		) : (
			<>
				{descriptionLines.map((line) => (
					<p class={line.startsWith('-') ? 'leadership-card__text leadership-card__bullet' : 'leadership-card__text'}>
						{line.startsWith('-') ? line.slice(1).trim() : line}
					</p>
				))}
			</>
		)}
	</div>
</article>

<style>
	/* LEADERSHIP CARD — PROTECTED DESIGN — DO NOT MODIFY WITHOUT APPROVAL */
	.leadership-card {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 2.25rem);
		padding: clamp(2.25rem, 4.5vw, 3rem);
		width: 100%;
		border-radius: 18px;
		border: 1px solid var(--card-border-dark);
		box-shadow: var(--card-shadow-dark);
		color: var(--text-on-dark);
		background: var(--card-bg-dark);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.leadership-card:hover {
		box-shadow:
			0 18px 48px rgba(0, 0, 0, 0.4),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.15);
		transform: translateY(-3px);
	}

	.leadership-card--feature {
		padding: clamp(0.1rem, 1vw, 1rem);
		gap: clamp(0.1rem, 0.1vw, 0.1rem);
		max-width: 30%;
	}

	.card.card--dark.leadership-card.leadership-card--feature {
		padding: clamp(0.1rem, 1vw, 1rem);
		gap: clamp(0.1rem, 0.1vw, 0.1rem);
		max-width: 30%;
	}

	.leadership-card__header {
		flex-shrink: 0;
	}

	.leadership-card__body {
		display: flex;
		flex-direction: column;
		gap: clamp(0.75rem, 1.5vw, 1.125rem);
		flex: 1;
	}

	.leadership-card h3,
	.leadership-card p,
	.leadership-card__links {
		margin: 0;
	}

	.leadership-card h3 {
		font-size: clamp(1.25rem, 2.1vw, 1.5rem);
		line-height: 1.25;
		color: var(--text-on-dark);
		letter-spacing: -0.015em;
	}

	.leadership-card__text {
		font-size: clamp(1rem, 1.5vw, 1.125rem);
		line-height: 1.75;
		color: var(--text-on-dark);
		opacity: 0.92;
	}

	.leadership-card__bullet {
		display: flex;
		align-items: flex-start;
		gap: 0.9375rem;
		padding-left: 0.375rem;
	}

	.leadership-card__bullet::before {
		content: '';
		flex-shrink: 0;
		width: 7.5px;
		height: 7.5px;
		border-radius: 50%;
		background: var(--accent);
		margin-top: 0.825rem;
		opacity: 0.9;
	}

	.leadership-card__links {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(0.75rem, 1.5vw, 1.125rem);
		margin-top: clamp(0.75rem, 1.5vw, 1.125rem);
		padding-left: 0;
	}

	.leadership-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.5625rem;
		padding: clamp(0.75rem, 1.5vw, 0.9375rem) clamp(1.3125rem, 2.25vw, 1.5rem);
		font-size: clamp(1.275rem, 1.5vw, 1.425rem);
		font-weight: 500;
		color: var(--accent);
		background: rgba(255, 179, 167, 0.12);
		border: 1px solid rgba(255, 179, 167, 0.3);
		border-radius: 12px;
		text-decoration: none;
		transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
	}

	.leadership-card__link:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--text-on-dark);
		transform: translateY(-1.5px);
	}

	.leadership-card__link-icon {
		flex-shrink: 0;
		width: 21px;
		height: 21px;
		opacity: 0.8;
	}

	@media (min-width: 768px) {
		.leadership-card--feature .leadership-card__body {
			/* Feature card can have slightly different layout if needed */
		}
	}

	/* Collapsible card details/summary styles */
	.leadership-card__details {
		margin-top: 0.5rem;
	}

	.leadership-card__summary {
		list-style: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.5rem 0.75rem;
		font-size: clamp(0.875rem, 1.1vw, 1rem);
		font-weight: 500;
		color: var(--accent);
		background: rgba(255, 179, 167, 0.1);
		border: 1px solid rgba(255, 179, 167, 0.3);
		border-radius: 999px;
		transition: background 0.2s ease, color 0.2s ease;
		cursor: pointer;
	}

	.leadership-card__summary::-webkit-details-marker {
		display: none;
	}

	.leadership-card__summary::after {
		content: '';
		width: 0.5rem;
		height: 0.5rem;
		border-right: 2px solid currentColor;
		border-bottom: 2px solid currentColor;
		transform: rotate(45deg);
		transition: transform 0.2s ease;
		margin-left: 0.5rem;
		flex-shrink: 0;
	}

	.leadership-card__details[open] .leadership-card__summary::after {
		transform: rotate(-135deg);
	}

	.leadership-card__summary:hover {
		background: var(--accent);
		color: var(--text-on-dark);
	}

	.leadership-card__summary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.leadership-card__preview {
		opacity: 0.8;
	}

	.leadership-card__full {
		animation: fadeIn 0.3s ease;
		margin-top: 0.75rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--card-border-dark);
	}

	.leadership-card__expand-icon {
		flex-shrink: 0;
		transition: transform 0.2s ease;
	}

	.leadership-card__details[open] .leadership-card__expand-icon {
		transform: rotate(180deg);
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(-0.5rem); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* Mobile: wider cards, shorter height */
	@media (max-width: 767px) {
		.leadership-card {
			width: calc(100vw - 1.5rem);
			padding: clamp(1rem, 3vw, 1.5rem);
			gap: clamp(0.75rem, 2vw, 1rem);
			border-radius: 12px;
		}

        .leadership-card--feature {
            padding: clamp(1.5rem, 4vw, 2rem);
            max-width: 90% !important;
        }
        .card.card--dark.leadership-card.leadership-card--feature {
            max-width: 90% !important;
        }

		.leadership-card__body {
			gap: clamp(0.5rem, 1.5vw, 0.75rem);
		}

		.leadership-card h3 {
			font-size: clamp(1.1rem, 3vw, 1.25rem);
		}

		.leadership-card__text {
			font-size: clamp(0.875rem, 2vw, 1rem);
		}

		.leadership-card__links {
			gap: clamp(0.5rem, 1.5vw, 0.75rem);
			margin-top: clamp(0.5rem, 1.5vw, 0.75rem);
		}

		.leadership-card__link {
			padding: clamp(0.625rem, 1.25vw, 0.75rem) clamp(1rem, 2vw, 1.125rem);
			font-size: clamp(1.125rem, 2.5vw, 1.25rem);
		}
	}
</style>