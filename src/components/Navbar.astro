---
const links = [
	{ label: 'About', href: '#about' },
	{ label: 'Leadership', href: '#leadership' },
	{ label: 'Projects', href: '#projects' },
	{ label: 'Awards', href: '#awards' },
	{ label: 'Skills', href: '#skills' },
	{ label: 'Contact', href: '#contact' },
];
---

<nav class="navbar" aria-label="Primary" style="background: var(--navbar-bg);">
	<div class="navbar__inner">
		<a class="navbar__brand" href="#top">Sundeep</a>
		<ul class="navbar__links">
			{links.map((link) => (
				<li class="navbar__item">
					<a class="navbar__link" href={link.href}>{link.label}</a>
				</li>
			))}
		</ul>
	</div>
</nav>

<style>
	.navbar {
		position: sticky;
		top: 0;
		z-index: 10;
		width: 100%;
	}

	.navbar__inner {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2.25rem;
		padding: 1.3125rem 1.5rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		white-space: nowrap;
	}

	.navbar__brand {
		flex: 0 0 auto;
		font-size: clamp(1.5rem, 2.25vw, 1.6875rem);
		font-weight: 600;
	}

	.navbar__links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.navbar__item {
		flex: 0 0 auto;
	}

	.navbar__link {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		font-size: clamp(1.125rem, 1.35vw, 1.2375rem);
		font-weight: 500;
		color: var(--text-primary);
		transition: opacity 0.2s ease;
	}

	.navbar__link:hover {
		opacity: 0.7;
	}

	@media (max-width: 767px) {
		.navbar__inner {
			justify-content: flex-start;
			padding: 1.125rem 1.5rem;
			gap: 1.5rem;
		}
	}

	@media (min-width: 768px) {
		.navbar__inner {
			justify-content: center;
		}
	}
</style>