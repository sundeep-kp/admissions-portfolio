---
import { timelineItems } from '../data/timeline';
import { aboutCards } from '../data/about';
import Carousel from './Carousel.astro';
import CarouselSlide from './CarouselSlide.astro';
---

<section class="ornithopter" aria-labelledby="ornithopter-title" id="ornithopter">
  <div class="ornithopter__gradient-top" aria-hidden="true"></div>

  <div class="ornithopter__inner">
    <div class="ornithopter__video-wrap" aria-label="Ornithopter video">
      <div class="ornithopter__video-inner">
        <video
          class="ornithopter__video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          aria-label="Looping ornithopter video"
        >
<source src="/admissions-portfolio/videos/ornithopter%20-%20CROP%20-%20Videobolt.net.mp4" type="video/mp4" />
<source src="/admissions-portfolio/videos/ornithopter.webm" type="video/webm" />
        </video>
      </div>
      <p class="ornithopter__video-caption" aria-hidden="true">~my ornithopter bird mechanism</p>

      <button class="ornithopter__about-toggle" aria-expanded="false" aria-controls="ornithopter-about-carousel" type="button">
        About me
      </button>

      <div class="ornithopter__about-carousel" aria-label="About me" id="ornithopter-about-carousel" hidden>
        <h3 class="ornithopter__about-title">About me</h3>
<Carousel
			id="about-carousel"
			autoplay={false}
			showArrows={true}
			showDots={false}
			class="about-carousel"
		>
          {aboutCards.map((card) => (
            <CarouselSlide>
              <article class="about-card about-carousel__card">
                <h3>{card.title}</h3>
                <ul>
                  {card.items.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            </CarouselSlide>
          ))}
        </Carousel>
      </div>
    </div>

    <div class="ornithopter__timeline">
      <h2 id="ornithopter-title">Timeline</h2>
      <ul>
        {timelineItems.map((item) => (
          <li>
            <p>{item.year}</p>
            <h3>{item.title}</h3>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="ornithopter__gradient-bottom" aria-hidden="true"></div>
</section>

<script>
	// Mobile about carousel toggle
	const toggle = document.querySelector('.ornithopter__about-toggle');
	const carousel = document.getElementById('ornithopter-about-carousel');
	if (toggle && carousel) {
		toggle.addEventListener('click', () => {
			const isHidden = carousel.hasAttribute('hidden');
			if (isHidden) {
				carousel.hidden = false;
				toggle.setAttribute('aria-expanded', 'true');
				toggle.textContent = 'Hide about';
				
				// Refresh splide when shown (slides were 0 width when hidden)
				const splideEl = carousel.querySelector('.splide');
				if (splideEl?.splide) {
					splideEl.splide.refresh();
				}
			} else {
				carousel.hidden = true;
				toggle.setAttribute('aria-expanded', 'false');
				toggle.textContent = 'About me';
			}
		});
	}
</script>

<style>
  .ornithopter {
    position: relative;
    background: var(--bg-neutral);
    padding: 0 var(--section-padding-inline);
  }

  .ornithopter__gradient-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: clamp(180px, 30vw, 450px);
    background: linear-gradient(180deg, #f6f7f9 0%, var(--bg-neutral) 100%);
    pointer-events: none;
  }

  .ornithopter__gradient-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0
    height: clamp(180px, 30vw, 450px);
    background: linear-gradient(180deg, var(--bg-neutral) 0%, #f6f7f9 100%);
    pointer-events: none;
  }

  .ornithopter__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(2.25rem, 4.5vw, 6rem);
    width: 100%;
    margin: 0 auto;
    padding-block: clamp(3rem, 8vw, 6rem);
  }

  .ornithopter__timeline,
  .ornithopter__video-wrap,
  .ornithopter__video {
    min-width: 0;
  }

  .ornithopter__timeline ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(1.125rem, 1.8vw, 1.65rem);
    align-items: flex-start;
  }

  .ornithopter__timeline h2,
  .ornithopter__timeline h3,
  .ornithopter__timeline p {
    margin: 0;
    color: var(--text-primary);
  }

  .ornithopter__video-wrap {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    overflow: hidden; /* mask left 3px black stripe — do not remove */
    min-height: 0;
  }

  .ornithopter__video-inner {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    mask-image:
      linear-gradient(to right, transparent, black 12%, black 88%, transparent),
      linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
    mask-composite: intersect;
    -webkit-mask-image:
      linear-gradient(to right, transparent, black 12%, black 88%, transparent),
      linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
    -webkit-mask-composite: source-in;
    background: rgba(213, 213, 213, 0.12);
  }

  .ornithopter__video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transform: translateX(-4.5px);
  }

  .ornithopter__video-caption {
    margin: 0.75rem 0 0;
    font-size: clamp(0.875rem, 1.1vw, 1rem);
    line-height: 1.5;
    color: var(--text-primary);
    opacity: 0.6;
    font-style: italic;
    text-align: center;
  }

  /* Mobile About toggle button */
  .ornithopter__about-toggle {
    display: none;
    margin-top: 1rem;
    padding: 0.75rem 1.5rem;
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    font-weight: 500;
    color: var(--text-primary);
    background: var(--bg-white);
    border: 1px solid var(--card-border);
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }

  .ornithopter__about-toggle:hover {
    background: var(--bg-white);
    border-color: var(--text-primary);
    color: var(--text-primary);
  }

  .ornithopter__about-toggle:focus-visible {
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
  }

  .ornithopter__about-carousel {
    display: none;
  }

  .ornithopter__about-carousel:not([hidden]) {
    display: block;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-0.5rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ornithopter__about-title {
    margin: 0 0 1rem;
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    font-weight: 600;
    color: var(--text-primary);
    text-align: center;
  }

  /* About carousel styles now handled by base Carousel.astro component.
   * Kept only: .ornithopter__about-toggle (mobile toggle button)
   * and .ornithopter__about-title (section title).
   * Card styling (.about-carousel__card) moved to base Carousel for consistency.
   */

  .about-carousel__card h3 {
    margin: 0;
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    line-height: 1.3;
    color: var(--text-primary);
  }

  .about-carousel__card ul {
    margin: 0;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.5rem;
  }

  .about-carousel__card li {
    margin: 0;
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.6;
    color: var(--text-primary);
    opacity: 0.85;
  }

  .ornithopter__timeline h2 {
    font-size: clamp(1.75rem, 2.5vw, 3rem);
    line-height: 1.1;
  }

  .ornithopter__timeline h3 {
    font-size: clamp(1.125rem, 1.4vw, 1.5rem);
    line-height: 1.3;
  }

  .ornithopter__timeline p {
    font-size: clamp(1rem, 1.1vw, 1.125rem);
    line-height: 1.6;
    opacity: 0.9;
  }

  .ornithopter__timeline li {
    display: flex;
    flex-direction: column;
    gap: 0.225rem;
    text-align: left;
    width: 100%;
  }

  @media (max-width: 767px) {
    .ornithopter__video-caption {
      display: block;
    }

    .ornithopter__about-toggle {
      display: block;
    }

    .ornithopter__about-carousel:not([hidden]) {
      display: block;
      animation: fadeIn 0.3s ease;
    }
  }

  @media (min-width: 768px) {
    .ornithopter__inner {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(3.75rem, 6vw, 7.5rem);
    }

    .ornithopter__timeline {
      flex: 0 0 35%;
      max-width: 35%;
      transform: translateX(-20%);
    }

    .ornithopter__video-wrap {
      flex: 0 0 65%;
      max-width: 65%;
      display: flex;
      flex-direction: column;
      gap: clamp(1.5rem, 3vw, 2rem);
    }

    .ornithopter__video-caption {
      display: block;
    }

    .ornithopter__about-toggle {
      display: none;
    }

    .ornithopter__about-carousel {
      display: block;
    }
  }
</style>