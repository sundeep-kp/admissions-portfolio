---
import { timelineItems } from '../data/timeline';
---

<section class="ornithopter" aria-labelledby="ornithopter-title" id="ornithopter">
  <div class="ornithopter__gradient-top" aria-hidden="true"></div>

  <div class="ornithopter__inner">
    <div class="ornithopter__timeline">
      <h2 id="ornithopter-title">Timeline</h2>
      <ul>
        {timelineItems.map((item) => (
          <li>
            <p>{item.year}</p>
            <h3>{item.title}</h3>
          </li>
        ))}
      </ul>
    </div>

    <div class="ornithopter__video-wrap" aria-label="Ornithopter video">
      <video
        class="ornithopter__video"
        src="/videos/ornithopter - CROP - Videobolt.net.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label="Looping ornithopter video"
      ></video>
    </div>
  </div>

  <div class="ornithopter__gradient-bottom" aria-hidden="true"></div>
</section>

<style>
  .ornithopter {
    position: relative;
    background: #2596be;
    padding: 0 clamp(1rem, 5vw, 4rem);
  }

  .ornithopter__gradient-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(180deg, white 0%, #2596be 100%);
    pointer-events: none;
  }

  .ornithopter__gradient-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(180deg, #2596be 0%, white 100%);
    pointer-events: none;
  }

  .ornithopter__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 4rem);
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding-block: clamp(3rem, 6vw, 6rem);
  }

  .ornithopter__timeline,
  .ornithopter__video-wrap,
  .ornithopter__video {
    min-width: 0;
  }

  .ornithopter__timeline ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: clamp(0.75rem, 1.2vw, 1.1rem);
  }

  .ornithopter__timeline h2,
  .ornithopter__timeline h3,
  .ornithopter__timeline p {
    margin: 0;
    color: white;
  }

  .ornithopter__video-wrap {
    width: 100%;
    overflow: hidden; /* mask left 3px black stripe — do not remove */
  }

  .ornithopter__video {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    display: block;
    transform: translateX(-3px); /* mask left 3px black stripe — do not remove */
  }

  .ornithopter__timeline h2 {
    font-size: clamp(1.75rem, 2.5vw, 3rem);
    line-height: 1.1;
  }

  .ornithopter__timeline h3 {
    font-size: clamp(1.125rem, 1.4vw, 1.5rem);
    line-height: 1.3;
  }

  .ornithopter__timeline p {
    font-size: clamp(1rem, 1.05vw, 1.1rem);
    line-height: 1.6;
    opacity: 0.9;
  }

  .ornithopter__timeline li {
    display: grid;
    gap: 0.15rem;
  }

  @media (min-width: 768px) {
    .ornithopter__inner {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(2.5rem, 4vw, 5rem);
    }

    .ornithopter__timeline {
      flex: 0 0 35%;
      max-width: 35%;
    }

    .ornithopter__video-wrap {
      flex: 0 0 65%;
      max-width: 65%;
    }
  }
</style>