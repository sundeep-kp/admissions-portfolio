---
interface ProjectLink {
	label: string;
	href: string;
}

interface Props {
	image?: string;
	title: string;
	category: string;
	description: string;
	links: ProjectLink[];
	status: string;
	tags: string[];
}

const { image, title, category, description, links, status, tags } = Astro.props as Props;
---

<article class="card card--light project-card">
	{image && <img class="project-card__image" src={image} alt={title} />}

	<div class="project-card__content">
		<p class="project-card__category">{category}</p>
		<h3 class="project-card__title">{title}</h3>
		<p class="project-card__description">{description}</p>

		{tags.length > 0 && (
			<ul class="project-card__tags" aria-label={`${title} tags`}>
				{tags.map((tag) => (
					<li>{tag}</li>
				))}
			</ul>
		)}

		<p class="project-card__status">{status}</p>

		{links.length > 0 && (
			<div class="project-card__links" aria-label={`${title} buttons`}>
				{links.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</div>
		)}
	</div>
</article>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		min-width: 0;
		width: 100%;
		border-radius: 12px;
		overflow: hidden;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.project-card:hover {
		box-shadow:
			0 8px 24px rgba(0, 0, 0, 0.06),
			inset 0 1px 0 rgba(255, 255, 255, 0.5);
		transform: translateY(-2px);
	}

	.project-card__image {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 12px 12px 0 0;
	}

	.project-card__content {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-width: 0;
		padding: clamp(1.5rem, 3vw, 2rem);
	}

	.project-card__category,
	.project-card__title,
	.project-card__description,
	.project-card__status,
	.project-card__tags {
		margin: 0;
	}

	.project-card__category {
		font-size: clamp(0.8rem, 0.9vw, 0.9rem);
		line-height: 1.4;
		color: var(--accent);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.project-card__title {
		font-size: clamp(1.125rem, 1.4vw, 1.5rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.project-card__description {
		font-size: clamp(0.95rem, 1vw, 1.05rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
		white-space: pre-line;
	}

	.project-card__tags {
		padding-left: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.project-card__tags li {
		font-size: clamp(0.75rem, 0.85vw, 0.85rem);
		line-height: 1.3;
		padding: 0.35rem 0.75rem;
		background: var(--accent-soft);
		color: var(--accent-strong);
		border-radius: 6px;
		font-weight: 500;
	}

	.project-card__status {
		font-size: clamp(0.8rem, 0.9vw, 0.9rem);
		line-height: 1.4;
		color: var(--text-primary);
		opacity: 0.6;
		font-style: italic;
	}

	.project-card__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	.project-card__links a {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1rem;
		font-size: clamp(0.85rem, 0.95vw, 0.95rem);
		font-weight: 500;
		color: var(--text-on-dark);
		background: var(--accent);
		border-radius: 8px;
		text-decoration: none;
		transition: background 0.2s ease, transform 0.15s ease;
	}

	.project-card__links a:hover {
		background: var(--accent-strong);
		transform: translateY(-1px);
	}
</style>