---
interface ProjectLink {
	label: string;
	href: string;
}

interface Props {
	image?: string;
	title: string;
	category: string;
	description: string;
	links: ProjectLink[];
	status: string;
	tags: string[];
}

const { image, title, category, description, links, status, tags } = Astro.props as Props;

// Create preview (first 45 chars)
const fullDescription = description;
const preview = fullDescription.length > 45 ? fullDescription.slice(0, 45) + '…' : fullDescription;
const isExpandable = fullDescription.length > 45;
---

<!-- 
  PROJECT CARD — PROTECTED DESIGN
  Do not modify layout, colors, typography, spacing, or hover effects without explicit approval.
  This card design is finalized for the admissions portfolio.
  Uses .card--light from global.css card system.
  Now with collapsible description (45 char preview) and smaller image (30% smaller).
-->

<article class="card card--light project-card">
	{image && (
		<img 
			class="project-card__image" 
			src={image} 
			alt={title} 
			style="max-width: 70%; height: auto; margin: 0 auto;"
		/>
	)}

	<div class="project-card__content">
		<p class="project-card__category">{category}</p>
		<h3 class="project-card__title">{title}</h3>
		
		{isExpandable ? (
			<details class="project-card__details">
				<summary class="project-card__summary">
					{preview}
				</summary>
				<div class="project-card__full">
					<p class="project-card__description">{description}</p>
				</div>
			</details>
		) : (
			<p class="project-card__description">{description}</p>
		)}

		{tags.length > 0 && (
			<ul class="project-card__tags" aria-label={`${title} tags`}>
				{tags.map((tag) => (
					<li>{tag}</li>
				))}
			</ul>
		)}

		<p class="project-card__status">{status}</p>

		{links.length > 0 && (
			<div class="project-card__links" aria-label={`${title} buttons`}>
				{links.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</div>
		)}
	</div>
</article>

<style>
	/* PROJECT CARD STYLES — DO NOT MODIFY WITHOUT APPROVAL */
	.project-card {
		display: flex;
		flex-direction: column;
		min-width: 0;
		width: 100%;
		border-radius: 18px;
		overflow: hidden;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
		margin: 0 auto;
	}

	.project-card:hover {
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.09),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transform: translateY(-3px);
	}

	.project-card__image {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 18px 18px 0 0;
		max-width: 70%;
		margin: 0 auto;
	}

	.project-card__content {
		display: flex;
		flex-direction: column;
		gap: 1.125rem;
		min-width: 0;
		padding: clamp(2.25rem, 4.5vw, 3rem);
	}

	.project-card__category,
	.project-card__title,
	.project-card__description,
	.project-card__status,
	.project-card__tags {
		margin: 0;
	}

	.project-card__category {
		font-size: clamp(1.2rem, 1.35vw, 1.35rem);
		line-height: 1.4;
		color: var(--accent);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.075em;
	}

	.project-card__title {
		font-size: clamp(1.25rem, 1.8vw, 1.75rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.project-card__description {
		font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
		white-space: pre-line;
	}

	.project-card__tags {
		padding-left: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.project-card__tags li {
		font-size: clamp(0.875rem, 1vw, 0.9375rem);
		line-height: 1.3;
		padding: 0.375rem 0.875rem;
		background: var(--accent-soft);
		color: var(--accent-strong);
		border-radius: 9px;
		font-weight: 500;
	}

	.project-card__status {
		font-size: clamp(0.875rem, 1vw, 0.9375rem);
		line-height: 1.4;
		color: var(--text-primary);
		opacity: 0.6;
		font-style: italic;
	}

	.project-card__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.75rem;
	}

	.project-card__links a {
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.5rem;
		font-size: clamp(1.275rem, 1.425vw, 1.425rem);
		font-weight: 500;
		color: var(--text-on-dark);
		background: var(--accent);
		border-radius: 12px;
		text-decoration: none;
		transition: background 0.2s ease, transform 0.15s ease;
	}

	.project-card__links a:hover {
		background: var(--accent-strong);
		transform: translateY(-1.5px);
	}

	/* Collapsible card details/summary styles */
	.project-card__details {
		margin-top: 0.5rem;
	}

	.project-card__summary {
		list-style: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.5rem 0.75rem;
		font-size: clamp(0.875rem, 1.1vw, 1rem);
		font-weight: 500;
		color: var(--accent);
		background: rgba(255, 179, 167, 0.1);
		border: 1px solid rgba(255, 179, 167, 0.3);
		border-radius: 999px;
		transition: background 0.2s ease, color 0.2s ease;
		cursor: pointer;
	}

	.project-card__summary::-webkit-details-marker {
		display: none;
	}

	.project-card__summary::after {
		content: '';
		width: 0.5rem;
		height: 0.5rem;
		border-right: 2px solid currentColor;
		border-bottom: 2px solid currentColor;
		transform: rotate(45deg);
		transition: transform 0.2s ease;
		margin-left: 0.5rem;
		flex-shrink: 0;
	}

	.project-card__details[open] .project-card__summary::after {
		transform: rotate(-135deg);
	}

	.project-card__summary:hover {
		background: var(--accent);
		color: var(--text-on-dark);
	}

	.project-card__summary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.project-card__full {
		animation: fadeIn 0.3s ease;
		margin-top: 0.75rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--card-border);
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(-0.5rem); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* Mobile: smaller images, smaller text, smaller padding */
	@media (max-width: 767px) {
		.project-card__image {
			max-width: 55%;
			border-radius: 12px 12px 0 0;
		}

		.project-card__content {
			padding: clamp(1.5rem, 3vw, 2rem);
			gap: clamp(0.75rem, 1.5vw, 1rem);
		}

		.project-card__category {
			font-size: clamp(1rem, 2vw, 1.125rem);
		}

		.project-card__title {
			font-size: clamp(1.125rem, 2.5vw, 1.375rem);
		}

		.project-card__description {
			font-size: clamp(0.875rem, 1.8vw, 1rem);
		}

		.project-card__tags {
			gap: 0.5rem;
		}

		.project-card__tags li {
			font-size: clamp(0.75rem, 1.8vw, 0.875rem);
			padding: 0.25rem 0.625rem;
		}

		.project-card__status {
			font-size: clamp(0.75rem, 1.5vw, 0.875rem);
		}

		.project-card__links a {
			padding: 0.625rem 1.125rem;
			font-size: clamp(1.125rem, 2.5vw, 1.25rem);
		}

		.project-card__summary {
			font-size: clamp(0.8125rem, 1.8vw, 0.9375rem);
			padding: 0.375rem 0.625rem;
		}

		.project-card__summary::after {
			width: 0.375rem;
			height: 0.375rem;
		}
	}
</style>