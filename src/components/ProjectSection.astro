---
import { projectGroups } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
import Carousel from './Carousel.astro';
import CarouselSlide from './CarouselSlide.astro';

const toId = (value: string) =>
	value
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '');

/*
 * PROJECTS CAROUSEL — DESIGN NOTES (aligned with About Me carousel philosophy)
 * - Single card per view (100% width) on all breakpoints — matches About Me carousel
 * - Carousel internal responsive logic mirrors About Me carousel:
 *   mobile: free scroll + snap (90% width), arrows/dots hidden
 *   desktop: controlled scroll via arrows/dots
 * - Arrow/dot colors themed for light background (projects section is white)
 * - ProjectCard has PROTECTED styles (see ProjectCard.astro) — do NOT override
 *   .project-card width/flex/padding in this component's <style>
 * - Arrow/dot theming via .projects__carousel in <style> below is INTENTIONAL
 *   for light background; do not remove without design review
 * - Expandable "Show all N projects" uses <details> + grid, NOT carousel
 */
---

<section class="projects section-fade" aria-labelledby="projects-title" id="projects" style="background: var(--bg-white); color: var(--text-primary);">
	<div class="projects__inner">
		<h2 id="projects-title">Featured Projects</h2>

		<div class="projects__groups">
			{projectGroups.map((group) => {
				return (
					<section
						class:list={['projects__group', { 'projects__group--compact': group.title === 'Machine Learning' }]}
						aria-labelledby={toId(group.title)}
					>
						<h3 id={toId(group.title)}>{group.title}</h3>
<Carousel
  id={toId(group.title) + '-carousel'}
  autoplay={false}
  showArrows={true}
  showDots={true}
  class="projects__carousel"
>
							{group.projects.map((project) => (
								<CarouselSlide>
									<ProjectCard
										image={project.image}
										title={project.title}
										category={project.category}
										description={project.description}
										links={project.links}
										status={project.status}
										tags={project.tags}
									/>
								</CarouselSlide>
							))}
					</Carousel>
					</section>
				);
			})}
		</div>
	</div>
</section>

<style>
	.projects {
		padding: var(--section-padding-block) var(--section-padding-inline);
	}

	.projects__inner {
		width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--section-gap);
	}

	.projects__groups {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--section-gap);
		width: 100%;
	}

	.projects__group {
		display: flex;
		flex-direction: column;
		gap: var(--card-gap);
		width: 100%;
		min-width: 0;
	}

	.projects__group--compact {
		max-width: 100%;
	}

	.projects h2,
	.projects h3 {
		margin: 0;
		line-height: 1.1;
	}

	.projects h2 {
		font-size: clamp(1.75rem, 2.5vw, 2.5rem);
	}

	.projects h3 {
		font-size: clamp(1.25rem, 2vw, 1.75rem);
	}

/* Carousel-specific styles for projects — theming only, not layout */
	.projects__carousel {
		width: 100%;
		position: relative;
	}

	.projects__carousel .splide__arrow {
		background: rgba(0, 0, 0, 0.75);
		color: var(--text-on-dark);
	}

	.projects__carousel .splide__arrow:hover:not(.is-disabled) {
		background: var(--accent);
	}

	.projects__carousel .splide__arrow svg {
		fill: var(--text-on-dark);
	}

	.projects__carousel .splide__pagination {
		padding: 1rem 0 0.5rem;
	}

	.projects__carousel .splide__pagination__page {
		background: var(--card-border);
	}

	.projects__carousel .splide__pagination__page:hover,
	.projects__carousel .splide__pagination__page.is-active {
		background: var(--accent);
	}
</style>