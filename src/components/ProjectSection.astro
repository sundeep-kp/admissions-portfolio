---
import { projectGroups } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
import Carousel from './Carousel.astro';

const toId = (value: string) =>
	value
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '');
---

<section class="projects section-fade" aria-labelledby="projects-title" id="projects" style="background: var(--bg-white); color: var(--text-primary);">
	<div class="projects__inner">
		<h2 id="projects-title">Featured Projects</h2>

		<div class="projects__groups">
			{projectGroups.map((group) => {
				return (
					<section
						class:list={['projects__group', { 'projects__group--compact': group.title === 'Machine Learning' }]}
						aria-labelledby={toId(group.title)}
					>
						<h3 id={toId(group.title)}>{group.title}</h3>
						<Carousel autoplay={false} showArrows={true} showDots={true} class="projects__carousel">
							{group.projects.map((project) => (
								<ProjectCard
									image={project.image}
									title={project.title}
									category={project.category}
									description={project.description}
									links={project.links}
									status={project.status}
									tags={project.tags}
								/>
							))}
					</Carousel>
					</section>
				);
			})}
		</div>
	</div>
</section>

<style>
	.projects {
		padding: var(--section-padding-block) var(--section-padding-inline);
	}

	.projects__inner {
		width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--section-gap);
	}

	.projects__groups {
		display: grid;
		gap: var(--section-gap);
	}

	.projects__group {
		display: flex;
		flex-direction: column;
		gap: var(--card-gap);
	}

	.projects__group--compact {
		max-width: 100%;
	}

	.projects h2,
	.projects h3 {
		margin: 0;
		line-height: 1.1;
	}

	.projects h2 {
		font-size: clamp(1.75rem, 2.5vw, 2.5rem);
	}

	.projects h3 {
		font-size: clamp(1.25rem, 2vw, 1.75rem);
	}

	/* Carousel-specific styles for projects */
	.projects__carousel {
		width: 100%;
	}

	.projects__carousel .carousel__track > * {
		flex: 0 0 100%;
		min-width: 0;
	}

	@media (min-width: 640px) {
		.projects__carousel .carousel__track > * {
			flex: 0 0 calc(50% - 0.75rem);
		}
	}

	@media (min-width: 1024px) {
		.projects__carousel .carousel__track > * {
			flex: 0 0 calc(33.333% - 1rem);
		}
	}

	/* Carousel arrow styling for projects */
	.projects__carousel .carousel__arrow {
		background: rgba(255, 255, 255, 0.95);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}

	.projects__carousel .carousel__arrow:hover {
		background: var(--accent);
		color: var(--text-on-dark);
	}

	.projects__carousel .carousel__dots {
		padding: 1rem 0 0.5rem;
	}

	.projects__carousel .carousel__dot {
		background: var(--card-border);
	}

	.projects__carousel .carousel__dot:hover {
		background: var(--accent);
	}

	.projects__carousel .carousel__dot--active {
		background: var(--accent);
	}
</style>