---
import { projectGroups } from '../data/projects';
import ProjectCard from './ProjectCard.astro';

const toId = (value: string) =>
	value
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '');
---

<section class="projects section-fade" aria-labelledby="projects-title" id="projects" style="background: var(--bg-white); color: var(--text-primary);">
	<div class="projects__inner">
		<h2 id="projects-title">Featured Projects</h2>

		<div class="projects__groups">
			{projectGroups.map((group) => (
				<section
					class:list={['projects__group', { 'projects__group--compact': group.title === 'Machine Learning' }]}
					aria-labelledby={toId(group.title)}
				>
					<h3 id={toId(group.title)}>{group.title}</h3>
					<div class="projects__grid">
						{group.projects.map((project) => (
							<ProjectCard
								image={project.image}
								title={project.title}
								category={project.category}
								description={project.description}
								links={project.links}
								status={project.status}
								tags={project.tags}
							/>
						))}
					</div>
				</section>
			))}
		</div>
	</div>
</section>

<style>
	.projects {
		padding: clamp(3rem, 6vw, 6rem) clamp(1rem, 5vw, 4rem);
	}

	.projects__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 3rem);
	}

	.projects__groups {
		display: grid;
		gap: clamp(2rem, 4vw, 4rem);
	}

	.projects__group {
		display: flex;
		flex-direction: column;
		gap: clamp(1rem, 2vw, 1.5rem);
	}

	.projects__group--compact {
		max-width: 100%;
	}

	.projects__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1rem, 2vw, 1.5rem);
		width: 100%;
	}

	.projects__group--compact .projects__grid {
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
	}

	.projects h2,
	.projects h3 {
		margin: 0;
		line-height: 1.1;
	}

	.projects h2 {
		font-size: clamp(1.75rem, 2.5vw, 3rem);
	}

	.projects h3 {
		font-size: clamp(1.25rem, 1.6vw, 1.75rem);
	}
</style>