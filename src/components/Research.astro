---
import ResearchCard from './ResearchCard.astro';

const researchTopics = ['Bio inspired robotics', 'for Planetary exploration', 'Non-Invasive Wildlife Observation'];

const researchSections = [
	{ 
		title: 'Currently Reading',
		items: [
			'Design of Machinery by R.L. Norton',
			'Introduction to Robotics by S.B. Niku',
			'Modern Robotics by Lynch & Park',
		]
	},
	{ 
		title: 'Research Directions',
		items: [
			'Gait optimization for legged robots',
			'Bio-inspired multi-legged locomotion (spider/hexapod)',
			'Terrain adaptation for planetary exploration',
			'Non-invasive wildlife monitoring via robotic platforms',
		]
	},
	{ 
		title: 'Future Topics',
		items: [
			'Soft robotics for delicate sample collection',
			'Swarm coordination for distributed sensing',
			'Energy-autonomous systems for long-duration missions',
		]
	},
];
---

<section class="research section-fade" aria-labelledby="research-title" id="research" style="background: var(--bg-white); color: var(--text-primary);">
	<div class="research__inner">
		<h2 id="research-title">Research Interests</h2>

		<div class="research__grid research__grid--topics">
			{researchTopics.map((topic) => (
				<ResearchCard title={topic} />
			))}
		</div>

		<div class="research__grid research__grid--sections">
			{researchSections.map((section) => (
				<ResearchCard title={section.title}>
					<ul>
						{section.items.map((item) => <li>{item}</li>)}
					</ul>
				</ResearchCard>
			))}
		</div>
	</div>
</section>

<style>
	.research {
		padding: clamp(4.5rem, 9vw, 9rem) clamp(1.5rem, 7.5vw, 6rem);
	}

	.research__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(2.25rem, 4.5vw, 4.5rem);
	}

	.research__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1.5rem, 3vw, 2.25rem);
		width: 100%;
	}

	.research__grid--topics {
		margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
	}

	.research h2 {
		margin: 0;
		font-size: clamp(2.625rem, 3.75vw, 4.5rem);
		line-height: 1.1;
	}
</style>
