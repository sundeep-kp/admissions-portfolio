---
import ResearchCard from './ResearchCard.astro';

const researchTopics = ['Bio inspired robotics', 'for Planetary exploration', 'Non-Invasive Wildlife Observation'];

const researchSections = [
	{ title: 'Currently Reading' },
	{ title: 'Research Directions' },
	{ title: 'Future Topics' },
];
---

<section class="research section-fade" aria-labelledby="research-title" id="research" style="background: #ffffff; color: #1a1a1a;">
	<div class="research__inner">
		<h2 id="research-title">Research Interests</h2>

		<div class="research__grid research__grid--topics">
			{researchTopics.map((topic) => (
				<ResearchCard title={topic} />
			))}
		</div>

		<div class="research__grid research__grid--sections">
			{researchSections.map((section) => (
				<ResearchCard title={section.title}>
					<p>[description missing, add about 50 words here]</p>
				</ResearchCard>
			))}
		</div>
	</div>
</section>

<style>
	.research {
		padding: clamp(3rem, 6vw, 6rem) clamp(1rem, 5vw, 4rem);
	}

	.research__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 3rem);
	}

	.research__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1rem, 2vw, 1.5rem);
		width: 100%;
	}

	.research__grid--topics {
		margin-bottom: clamp(1rem, 2vw, 1.5rem);
	}

	.research h2 {
		margin: 0;
		font-size: clamp(1.75rem, 2.5vw, 3rem);
		line-height: 1.1;
	}
</style>
