---
interface Props {
	title: string;
}

const { title } = Astro.props as Props;
---

<article class="card card--light research-card">
	<h3>{title}</h3>
	<div class="research-card__body">
		<slot />
	</div>
</article>

<style>
	/* RESEARCH CARD — DO NOT MODIFY WITHOUT APPROVAL */
	.research-card {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding: clamp(2.25rem, 4.5vw, 3rem);
		width: 100%;
		border-radius: 18px;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.research-card:hover {
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.09),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.75);
		transform: translateY(-3px);
	}

	.research-card h3,
	.research-card__body {
		margin: 0;
	}

	.research-card h3 {
		font-size: clamp(1.125rem, 1.5vw, 1.375rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.research-card__body {
		font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
	}

	.research-card__body ul {
		margin: 0;
		padding-left: 0;
		list-style: none;
		display: grid;
		gap: 0.5rem;
	}

	.research-card__body li {
		font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
	}

	.research-card__body li::before {
		content: '';
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		margin-right: 0.75rem;
		margin-top: 0.5rem;
		vertical-align: top;
	}
</style>