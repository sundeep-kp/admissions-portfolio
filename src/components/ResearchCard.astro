---
interface Props {
	title: string;
}

const { title } = Astro.props as Props;
---

<article class="research-card">
	<h3>{title}</h3>
	<div class="research-card__body">
		<slot />
	</div>
</article>

<style>
	.research-card {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: clamp(1.25rem, 2.5vw, 2rem);
		width: 100%;
	}

	.research-card h3,
	.research-card__body {
		margin: 0;
	}

	.research-card h3 {
		font-size: clamp(1.125rem, 1.4vw, 1.5rem);
		line-height: 1.25;
	}

	.research-card__body {
		font-size: clamp(1rem, 1.05vw, 1.1rem);
		line-height: 1.65;
	}
</style>