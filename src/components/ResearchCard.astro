---
interface Props {
	title: string;
}

const { title } = Astro.props as Props;
---

<article class="card card--light research-card">
	<h3>{title}</h3>
	<div class="research-card__body">
		<slot />
	</div>
</article>

<style>
	.research-card {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: clamp(1.5rem, 3vw, 2rem);
		width: 100%;
		border-radius: 12px;
	}

	.research-card h3,
	.research-card__body {
		margin: 0;
	}

	.research-card h3 {
		font-size: clamp(1.125rem, 1.4vw, 1.5rem);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.research-card__body {
		font-size: clamp(0.95rem, 1vw, 1.05rem);
		line-height: 1.7;
		color: var(--text-primary);
		opacity: 0.9;
	}
</style>