---
interface Props {
	title: string;
	chips: string[];
}

const { title, chips } = Astro.props as Props;
---

<article class="card card--dark skill-card">
	<h3>{title}</h3>
	<ul class="skill-card__chips" aria-label={title}>
		{chips.map((chip) => (
			<li>{chip}</li>
		))}
	</ul>
</article>

<style>
	.skill-card {
		min-width: 0;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: clamp(1.125rem, 2.25vw, 1.5rem);
		padding: clamp(2.25rem, 4.5vw, 3rem);
		border-radius: 24px;
		border: 1px solid var(--card-border-dark);
		box-shadow: var(--card-shadow-dark);
		background: var(--card-bg-dark);
		color: var(--text-on-dark);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.skill-card:hover {
		box-shadow:
			0 18px 48px rgba(0, 0, 0, 0.4),
			inset 0 1.5px 0 rgba(255, 255, 255, 0.1);
		transform: translateY(-3px);
	}

	.skill-card h3,
	.skill-card__chips {
		margin: 0;
	}

	.skill-card h3 {
		font-size: clamp(1.6875rem, 2.1vw, 2.25rem);
		line-height: 1.25;
		color: var(--text-on-dark);
	}

	.skill-card__chips {
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.skill-card__chips li {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 1.125rem;
		line-height: 1.2;
		overflow-wrap: anywhere;
		background: var(--chip-bg);
		border-radius: 9px;
		border: 1px solid var(--chip-border);
		color: var(--text-on-dark);
		font-size: clamp(1.2rem, 1.35vw, 1.35rem);
		font-weight: 500;
	}
</style>