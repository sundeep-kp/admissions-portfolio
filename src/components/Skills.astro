---
import { skillGroups } from '../data/skills';
import SkillCard from './SkillCard.astro';
---

<section class="skills section-fade" aria-labelledby="skills-title" id="skills" style="background: #324b4c; color: white;">
	<div class="skills__inner">
		<h2 id="skills-title">Skills</h2>

		<div class="skills__grid">
			{skillGroups.map((group) => (
				<SkillCard title={group.title} chips={group.chips} />
			))}
		</div>
	</div>
</section>

<style>
	.skills {
		padding: clamp(3rem, 6vw, 6rem) clamp(1rem, 5vw, 4rem);
	}

	.skills__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 3rem);
	}

	.skills__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1rem, 2vw, 1.5rem);
		width: 100%;
	}

	.skills h2 {
		margin: 0;
		font-size: clamp(1.75rem, 2.5vw, 3rem);
		line-height: 1.1;
	}

	/* auto-fit handles desktop expansion without fixed breakpoints */
</style>