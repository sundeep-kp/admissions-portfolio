---
import { skillGroups } from '../data/skills';
import SkillCard from './SkillCard.astro';
---

<section class="skills section-fade" aria-labelledby="skills-title" id="skills" style="background: var(--accent); color: var(--text-on-dark);">
	<div class="skills__inner">
		<h2 id="skills-title">Skills</h2>

		<div class="skills__grid">
			{skillGroups.map((group) => (
				<SkillCard title={group.title} chips={group.chips} />
			))}
		</div>
	</div>
</section>

<style>
	.skills {
		padding: clamp(4.5rem, 9vw, 9rem) clamp(1.5rem, 7.5vw, 6rem);
	}

	.skills__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: clamp(2.25rem, 4.5vw, 4.5rem);
	}

	.skills__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 34ch), 1fr));
		gap: clamp(1.5rem, 3vw, 2.25rem);
		width: 100%;
	}

	.skills h2 {
		margin: 0;
		font-size: clamp(2.625rem, 3.75vw, 4.5rem);
		line-height: 1.1;
	}

	/* auto-fit handles desktop expansion without fixed breakpoints */
</style>