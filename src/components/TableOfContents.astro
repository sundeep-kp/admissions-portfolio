---
const sections = [
	{ id: 'ornithopter', label: 'Timeline' },
	{ id: 'leadership', label: 'Leadership' },
	{ id: 'projects', label: 'Projects' },
	{ id: 'awards', label: 'Awards' },
	{ id: 'skills', label: 'Skills' },
	{ id: 'learning', label: 'Learning' },
	{ id: 'hobbies', label: 'Hobbies' },
	{ id: 'contact', label: 'Contact' },
];
---

<nav class="toc" aria-label="Table of contents">
	<ul class="toc__list">
		{sections.map((section) => (
			<li class="toc__item">
				<a class="toc__link" href={`#${section.id}`} data-toc-link>{section.label}</a>
			</li>
		))}
	</ul>
</nav>

<script>
	// IntersectionObserver to highlight active section
	const links = document.querySelectorAll('.toc__link');
	const sectionElements = Array.from(links).map(link => document.querySelector(link.getAttribute('href'))).filter(Boolean);

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const id = entry.target.id;
				links.forEach(link => {
					link.classList.toggle('toc__link--active', link.getAttribute('href') === `#${id}`);
				});
			}
		});
	}, {
		rootMargin: '-20% 0px -60% 0px',
		threshold: 0.1
	});

	sectionElements.forEach(el => observer.observe(el));
</script>

<style>
	.toc {
		position: fixed;
		right: 0;
		top: calc(6% + 4rem);
		max-height: calc(100vh - 8rem);
		overflow-y: auto;
		width: 160px;
		background: var(--bg-white);
		border-left: 1px solid var(--card-border);
		border-radius: 12px 0 0 12px;
		box-shadow: -4px 0 24px rgba(0, 0, 0, 0.05);
		z-index: 100;
		padding: 0.75rem 0;
		transform: translateX(100%);
		animation: slideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	@keyframes slideIn {
		from {
			transform: translateX(100%);
			opacity: 0;
		}
		to {
			transform: translateX(0);
			opacity: 1;
		}
	}

	.toc__list {
		margin: 0;
		padding: 0 0.75rem;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.toc__item {
		opacity: 0;
		transform: translateX(20px);
		animation: fadeInItem 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	@keyframes fadeInItem {
		from {
			opacity: 0;
			transform: translateX(20px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.toc__item:nth-child(1) { animation-delay: 0.1s; }
	.toc__item:nth-child(2) { animation-delay: 0.15s; }
	.toc__item:nth-child(3) { animation-delay: 0.2s; }
	.toc__item:nth-child(4) { animation-delay: 0.25s; }
	.toc__item:nth-child(5) { animation-delay: 0.3s; }
	.toc__item:nth-child(6) { animation-delay: 0.35s; }
	.toc__item:nth-child(7) { animation-delay: 0.4s; }
	.toc__item:nth-child(8) { animation-delay: 0.45s; }
	.toc__item:nth-child(9) { animation-delay: 0.5s; }

	.toc__list {
		margin: 0;
		padding: 0 0.75rem;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.toc__link {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.5rem;
		padding: 0.625rem 0.75rem;
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--text-primary);
		text-decoration: none;
		border-radius: 6px;
		transition: color 0.2s ease, background 0.2s ease, padding-right 0.2s ease;
		opacity: 0.7;
	}

	.toc__link:hover {
		opacity: 1;
		background: var(--accent-soft);
		color: var(--accent);
		padding-right: 1rem;
	}

	.toc__link--active {
		opacity: 1;
		color: var(--accent);
		background: var(--accent-soft);
		font-weight: 500;
	}

	.toc__link::before {
		content: '';
		width: 3px;
		height: 0;
		background: var(--accent);
		border-radius: 2px;
		transition: height 0.3s ease;
		margin-right: 0.5rem;
		opacity: 0;
	}

	.toc__link--active::before,
	.toc__link:hover::before {
		height: 100%;
		opacity: 1;
	}

	@media (max-width: 1023px) {
		.toc {
			display: none;
		}
	}
</style>