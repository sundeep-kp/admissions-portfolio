---
const sections = [
	{ id: 'about', label: 'About', short: 'AB' },
	{ id: 'ornithopter', label: 'Timeline', short: 'TL' },
	{ id: 'leadership', label: 'Leadership', short: 'LD' },
	{ id: 'projects', label: 'Projects', short: 'PJ' },
	{ id: 'awards', label: 'Awards', short: 'AW' },
	{ id: 'skills', label: 'Skills', short: 'SK' },
	{ id: 'learning', label: 'Learning', short: 'LN' },
	{ id: 'hobbies', label: 'Hobbies', short: 'HB' },
	{ id: 'contact', label: 'Contact', short: 'CT' },
];
---

<nav class="toc" aria-label="Table of contents">
	<ul class="toc__list">
		{sections.map((section) => (
			<li class="toc__item">
				<a class="toc__link" href={`#${section.id}`} data-toc-link>
					<span class="toc__short">{section.short}</span>
					<span class="toc__label">{section.label}</span>
				</a>
			</li>
		))}
	</ul>
</nav>

<script>
	// IntersectionObserver to highlight active section
	const links = document.querySelectorAll('.toc__link');
	const sectionElements = Array.from(links).map(link => document.querySelector(link.getAttribute('href'))).filter(Boolean);

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const id = entry.target.id;
				links.forEach(link => {
					link.classList.toggle('toc__link--active', link.getAttribute('href') === `#${id}`);
				});
			}
		});
	}, {
		rootMargin: '-20% 0px -60% 0px',
		threshold: 0.1
	});

	sectionElements.forEach(el => observer.observe(el));
</script>

<style>
	.toc {
		position: fixed;
		right: 0;
		top: calc(6% + 4rem);
		max-height: calc(100vh - 8rem);
		overflow-y: auto;
		width: 60px;
		background: var(--bg-white);
		border-left: 1px solid var(--card-border);
		border-radius: 12px 0 0 12px;
		box-shadow: -4px 0 24px rgba(0, 0, 0, 0.05);
		z-index: 100;
		padding: 0.75rem 0;
	}

	.toc__list {
		margin: 0;
		padding: 0 0.5rem;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.toc__link {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		font-size: 0.75rem;
		line-height: 1.4;
		color: var(--text-primary);
		text-decoration: none;
		border-radius: 6px;
		transition: color 0.2s ease, background 0.2s ease, width 0.2s ease;
		opacity: 0.6;
		white-space: nowrap;
		overflow: hidden;
	}

	.toc__short {
		font-weight: 600;
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		flex-shrink: 0;
	}

	.toc__label {
		opacity: 0;
		width: 0;
		overflow: hidden;
		transition: opacity 0.2s ease, width 0.2s ease;
	}

	.toc__link:hover {
		opacity: 1;
		background: var(--accent-soft);
		color: var(--accent);
		width: max-content;
		padding-right: 1rem;
	}

	.toc__link:hover .toc__label {
		opacity: 1;
		width: max-content;
	}

	.toc__link--active {
		opacity: 1;
		color: var(--accent);
		background: var(--accent-soft);
		font-weight: 500;
	}

	.toc__link--active .toc__label {
		opacity: 1;
		width: max-content;
	}

	@media (max-width: 1023px) {
		.toc {
			display: none;
		}
	}
</style>