---
const sections = [
	{ id: 'ornithopter', label: 'Timeline' },
	{ id: 'leadership', label: 'Leadership' },
	{ id: 'projects', label: 'Projects' },
	{ id: 'awards', label: 'Awards' },
	{ id: 'skills', label: 'Skills' },
	{ id: 'learning', label: 'Learning' },
	{ id: 'hobbies', label: 'Hobbies' },
	{ id: 'contact', label: 'Contact' },
];
---

<button class="toc__toggle" aria-label="Toggle sidebar" data-toc-toggle>
	<svg width="12" height="12" viewBox="0 0 12 12" fill="none">
		<path d="M8 2L4 6L8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
	</svg>
</button>
<nav class="toc" aria-label="Table of contents">
	<ul class="toc__list">
		{sections.map((section) => (
			<li class="toc__item">
				<a class="toc__link" href={`#${section.id}`} data-toc-link>{section.label}</a>
			</li>
		))}
	</ul>
</nav>

<script>
	// IntersectionObserver to highlight active section
	const links = document.querySelectorAll('.toc__link');
	const sectionElements = Array.from(links).map(link => document.querySelector(link.getAttribute('href'))).filter(Boolean);

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const id = entry.target.id;
				links.forEach(link => {
					link.classList.toggle('toc__link--active', link.getAttribute('href') === `#${id}`);
				});
			}
		});
	}, {
		rootMargin: '-20% 0px -60% 0px',
		threshold: 0.1
	});

	sectionElements.forEach(el => observer.observe(el));

	// Sidebar toggle
	const toc = document.querySelector('.toc');
	const toggleBtn = document.querySelector('[data-toc-toggle]');
	const savedState = localStorage.getItem('toc-hidden');

	if (savedState === 'true') {
		toc?.classList.add('toc--hidden');
		toggleBtn?.classList.add('toc__toggle--shifted');
	}

	toggleBtn?.addEventListener('click', () => {
		toc?.classList.toggle('toc--hidden');
		toggleBtn.classList.toggle('toc__toggle--shifted');
		localStorage.setItem('toc-hidden', toc?.classList.contains('toc--hidden') ? 'true' : 'false');
	});
</script>

<style>
	/*
	 * Table of Contents (Desktop Sidebar)
	 * 
	 * KEY DESIGN DECISIONS TO PREVENT REGRESSIONS:
	 * 1. Sidebar background = transparent (no container frosted glass).
	 *    Individual links have their own rgba(255,255,255,0.4) backgrounds
	 *    so text remains readable over any page section behind it.
	 * 2. Links are separate cards with gap: 0.75rem — not a single continuous bar.
	 *    Prevents "stripe" effect and lets page content show between items.
	 * 3. IntersectionObserver rootMargin: '-20% 0px -60% 0px'
	 *    Activates link when section enters middle 40% of viewport.
	 *    Adjust if sections are very short/tall.
	 * 4. Active state uses accent color + background, NOT blend modes.
	 *    Blend modes failed because sidebar transparency + page content
	 *    created unpredictable contrast.
	 * 5. Hidden on mobile (≤1023px) — mobile uses sticky navbar instead.
	 * 6. Animation: slide-in from right, staggered item fade-in.
	 */
	.toc {
		position: fixed;
		right: 0;
		top: calc(6% + 4rem);
		max-height: calc(100vh - 8rem);
		overflow-y: auto;
		width: 160px;
		background: transparent;
		border-left: 1px solid rgba(0, 0, 0, 0.06);
		border-radius: 12px 0 0 12px;
		z-index: 100;
		padding: 0.75rem 0;
		transform: translateX(0);
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.toc__list {
		margin: 0;
		padding: 0 0.75rem;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.toc__item {
		opacity: 0;
		transform: translateX(20px);
		animation: fadeInItem 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	@keyframes fadeInItem {
		from {
			opacity: 0;
			transform: translateX(20px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.toc__item:nth-child(1) { animation-delay: 0.1s; }
	.toc__item:nth-child(2) { animation-delay: 0.15s; }
	.toc__item:nth-child(3) { animation-delay: 0.2s; }
	.toc__item:nth-child(4) { animation-delay: 0.25s; }
	.toc__item:nth-child(5) { animation-delay: 0.3s; }
	.toc__item:nth-child(6) { animation-delay: 0.35s; }
	.toc__item:nth-child(7) { animation-delay: 0.4s; }
	.toc__item:nth-child(8) { animation-delay: 0.45s; }
	.toc__item:nth-child(9) { animation-delay: 0.5s; }

	/* Link cards — individual frosted glass rectangles */
	.toc__link {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--text-primary);
		text-decoration: none;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.4);
		transition: color 0.2s ease, background 0.2s ease, padding-right 0.2s ease, transform 0.2s ease;
		opacity: 0.8;
	}

	.toc__link:hover {
		opacity: 1;
		background: var(--accent-soft);
		color: var(--accent);
		padding-right: 1.25rem;
		transform: translateX(-2px);
	}

	.toc__link--active {
		opacity: 1;
		color: var(--accent);
		background: var(--accent-soft);
		font-weight: 500;
	}

	.toc__link--active::before,
	.toc__link:hover::before {
		height: 100%;
		opacity: 1;
	}

	.toc__link::before {
		content: '';
		width: 3px;
		height: 0;
		background: var(--accent);
		border-radius: 2px;
		transition: height 0.3s ease;
		margin-right: 0.5rem;
		opacity: 0;
	}

	@media (max-width: 1023px) {
		.toc {
			display: none;
		}
	}

	/* Toggle button — fixed position, outside sidebar overflow context */
	.toc__toggle {
		position: fixed;
		right: 160px;
		top: calc(6% + 4rem + 160px);
		width: 24px;
		height: 48px;
		background: rgba(255, 255, 255, 0.4);
		border: 1px solid rgba(0, 0, 0, 0.06);
		border-right: none;
		border-radius: 8px 0 0 8px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-primary);
		transition: background 0.2s ease;
		opacity: 0.6;
		z-index: 101;
	}

	.toc__toggle:hover {
		opacity: 1;
		background: var(--accent-soft);
	}

	/* Hidden state — slide out to the right */
	.toc--hidden {
		transform: translateX(100%);
	}

	.toc__toggle--shifted {
		right: 0;
		border-radius: 0 8px 8px 0;
		border-left: 1px solid rgba(0, 0, 0, 0.06);
		border-right: none;
	}
</style>