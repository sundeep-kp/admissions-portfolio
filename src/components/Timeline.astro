---
import { timelineItems } from '../data/timeline';
---

<section class="timeline" aria-labelledby="timeline-title" id="timeline">
	<div class="timeline__inner">
		<div class="timeline__list">
			<h2 id="timeline-title">Timeline</h2>
			<ul>
				{timelineItems.map((item) => (
					<li>
						<p>{item.year}</p>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</li>
				))}
			</ul>
		</div>

		<div class="timeline__visual" aria-label="Ornithopter video placeholder">
			<div class="timeline__video-placeholder">[Ornithopter video placeholder]</div>
		</div>
	</div>
</section>

<style>
	.timeline {
		padding-inline: clamp(1rem, 5vw, 4rem);
	}

	.timeline__inner {
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 4rem);
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
	}

	.timeline__list,
	.timeline__visual,
	.timeline__video-placeholder {
		min-width: 0;
	}

	.timeline__list ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: clamp(0.875rem, 1.4vw, 1.5rem);
	}

	.timeline__list h2,
	.timeline__list h3,
	.timeline__list p {
		margin: 0;
	}

	.timeline__visual {
		width: 100%;
	}

	.timeline__video-placeholder {
		aspect-ratio: 16 / 9;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 2vw, 1.5rem);
	}

	.timeline h2 {
		font-size: clamp(1.75rem, 2.5vw, 3rem);
		line-height: 1.1;
	}

	.timeline h3 {
		font-size: clamp(1.125rem, 1.4vw, 1.5rem);
		line-height: 1.3;
	}

	.timeline p {
		font-size: clamp(1rem, 1.05vw, 1.1rem);
		line-height: 1.6;
	}

	@media (min-width: 768px) {
		.timeline__inner {
			flex-direction: row;
			align-items: flex-start;
			gap: clamp(2.5rem, 4vw, 5rem);
		}

		.timeline__list {
			flex: 0 0 35%;
			max-width: 35%;
		}

		.timeline__visual {
			flex: 0 0 65%;
			max-width: 65%;
		}
	}
</style>