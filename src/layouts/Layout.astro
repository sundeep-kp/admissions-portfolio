---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = 'Admissions Portfolio', description = 'University transfer admissions portfolio.' } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/portfolio-website/favicon.svg" />
		<link rel="icon" href="/portfolio-website/favicon.ico" />
		<title>{title}</title>
	</head>
	<body id="top">
		<slot />
	</body>
</html>
