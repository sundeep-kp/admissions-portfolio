---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = 'Admissions Portfolio', description = 'University transfer admissions portfolio.' } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/admissions-portfolio/favicon.svg" />
		<link rel="icon" href="/admissions-portfolio/favicon.ico" />
		<title>{title}</title>
	</head>
	<body id="top">
		<slot />
	</body>
</html>

<style is:global>
	.page-grid {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding: 0;
	}

	.page-main {
		min-width: 0;
	}

	@media (min-width: 1024px) {
		.page-sidebar {
			position: fixed;
			right: 0;
			top: calc(6% + 4rem);
			width: 60px;
			max-height: calc(100vh - 8rem);
			overflow-y: auto;
			background: var(--bg-white);
			border-left: 1px solid var(--card-border);
			border-radius: 12px 0 0 12px;
			box-shadow: -4px 0 24px rgba(0, 0, 0, 0.05);
			z-index: 100;
			padding: 1rem 0.5rem;
		}
	}
</style>
